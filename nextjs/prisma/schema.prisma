  contactPhone  String?   @map("contact_phone")
  contactEmail  String?   @map("contact_email")
  description   String?   @db.Text
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  parent   AssetLocation?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children AssetLocation[] @relation("LocationHierarchy")
  assets   Asset[]

  @@index([parentId])
  @@map("asset_locations")
}

model Asset {
  id             BigInt    @id @default(autoincrement())
  name           String
  categoryId     BigInt?   @map("category_id")
  purchaseDate   DateTime? @map("purchase_date")
  supportedDate  DateTime? @map("supported_date")
  serialCode     String?   @map("serial_code")
  quantity       Int       @default(1)
  unitPrice      Decimal?  @map("unit_price")  @db.Decimal(15,2)
  purchaseCost   Decimal?  @map("purchase_cost") @db.Decimal(15,2)
  warrantyPeriod String?   @map("warranty_period")
  locationId     BigInt?   @map("location_id")
  description    String?   @db.Text
  image          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  category     AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  location     AssetLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assignments  AssetAssignment[]
  maintenances AssetMaintenance[]
  depreciations AssetDepreciation[]
  borrowRents  AssetBorrowRent[]

  @@index([categoryId])
  @@index([locationId])
  @@map("assets")
}

model AssetAssignment {
  id             BigInt    @id @default(autoincrement())
  assetId        BigInt    @map("asset_id")
  assignedTo     String    @map("assigned_to")
  assignedDate   DateTime  @map("assigned_date")
  expectedReturn DateTime? @map("expected_return")
  status         String    @default("active")
  condition      String    @default("excellent")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_assignments")
}

model AssetMaintenance {
  id                  BigInt    @id @default(autoincrement())
  assetId             BigInt    @map("asset_id")
  type                String    @default("Preventive")
  title               String
  description         String?   @db.Text
  scheduledDate       DateTime? @map("scheduled_date")
  completedDate       DateTime? @map("completed_date")
  cost                Decimal?  @db.Decimal(15,2)
  technicianName      String?   @map("technician_name")
  status              String    @default("Scheduled")
  priority            String    @default("Medium")
  nextMaintenanceDate DateTime? @map("next_maintenance_date")
  notes               String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_maintenances")
}

model AssetDepreciation {
  id         BigInt    @id @default(autoincrement())
  assetId    BigInt    @map("asset_id")
  method     String    @default("Straight Line")
  usefulLife Int       @default(5) @map("useful_life")
  salvageValue Decimal @default(0) @map("salvage_value") @db.Decimal(15,2)
  startDate  DateTime  @map("start_date")
  notes      String?   @db.Text
  status     String    @default("active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_depreciations")
}

model AssetBorrowRent {
  id               BigInt    @id @default(autoincrement())
  assetId          BigInt    @map("asset_id")
  userId           String    @map("user_id")
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  actualReturnDate DateTime? @map("actual_return_date")
  rentQuantity     Int       @default(1) @map("rent_quantity")
  purpose          String?   @db.Text
  status           String    @default("draft")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  asset    Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  payments AssetBorrowPayment[]

  @@index([assetId])
  @@map("asset_borrow_rents")
}

model AssetBorrowPayment {
  id              BigInt    @id @default(autoincrement())
  borrowRentId    BigInt    @map("borrow_rent_id")
  assetId         BigInt    @map("asset_id")
  customerName    String    @map("customer_name")
  paymentAmount   Decimal   @map("payment_amount") @db.Decimal(15,2)
  paymentDate     DateTime  @map("payment_date")
  referenceNumber String?   @map("reference_number")
  status          String    @default("draft")
  notes           String?   @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  borrowRent AssetBorrowRent @relation(fields: [borrowRentId], references: [id], onDelete: Cascade)

  @@index([borrowRentId])
  @@index([assetId])
  @@map("asset_borrow_payments")
}

// ─── WhatsApp Chat Addon ───────────────────────────────────────────────────────

model WaContact {
  id        BigInt    @id @default(autoincrement())
  name      String
  phone     String
  type      String    @default("custom")
  userId    BigInt?   @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  messages WaMessage[]

  @@map("wa_contacts")
}

model WaMessage {
  id        BigInt   @id @default(autoincrement())
  contactId BigInt   @map("contact_id")
  direction String   @default("outbound")
  message   String   @db.Text
  status    String   @default("sent")
  createdAt DateTime @default(now()) @map("created_at")

  contact WaContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("wa_messages")
}

model WaSetting {
  id        BigInt    @id @default(autoincrement())
  key       String    @unique
  value     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("wa_settings")
}

model WaEventNotification {
  id        BigInt    @id @default(autoincrement())
  event     String    @unique
  label     String
  isEnabled Boolean   @default(true) @map("is_enabled")
  template  String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("wa_event_notifications")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Storefronts add-on — tenant-scoped site builder (distinct from CustomPage / Media)
// organizationId → users.id (company tenant), same pattern as settings.createdBy
// ═══════════════════════════════════════════════════════════════════════════════

/// Published or draft storefront site for one tenant; hosts domains and pages.
model Website {
  id              BigInt    @id @default(autoincrement())
  organizationId  BigInt    @map("organization_id")
  name            String
  slug            String
  status          String    @default("draft") // draft | active | archived | suspended
  defaultLocale   String?   @map("default_locale") @db.VarChar(16)
  metadata        Json?
  createdById     BigInt?   @map("created_by_id")
  updatedById     BigInt?   @map("updated_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  organization User  @relation("SfWebsiteOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User? @relation("SfWebsiteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User? @relation("SfWebsiteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  domains              Domain[]
  themes               Theme[]
  pages                Page[]
  notificationTemplates NotificationTemplate[]
  notificationLogs     NotificationLog[]
  eventLogs            EventLog[]
  storefrontCustomers  StorefrontCustomer[]
  collections          StorefrontCollection[]
  blogPosts            StorefrontBlogPost[]
  storefrontCarts      StorefrontCart[]
  storefrontOrders     StorefrontOrder[]
  storefrontCheckoutSessions StorefrontCheckoutSession[]
  discountRules        StorefrontDiscountRule[]
  shippingZones        StorefrontShippingZone[]
  taxRules             StorefrontTaxRule[]
  taxSettings          StorefrontTaxSettings[]
  supportTickets       StTicket[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([slug])
  @@map("storefront_websites")
}

/// Merchandising group for storefront collection pages (Day 21 / 24).
model StorefrontCollection {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  websiteId      BigInt?   @map("website_id")
  slug           String
  title          String
  description    String?   @db.Text
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description") @db.Text
  published      Boolean   @default(false)
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  organization User     @relation("SfCollectionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  products     StorefrontCollectionProduct[]

  @@unique([organizationId, slug])
  @@index([organizationId, published])
  @@index([websiteId])
  @@map("storefront_collections")
}

model StorefrontCollectionProduct {
  id           BigInt @id @default(autoincrement())
  collectionId BigInt @map("collection_id")
  productId    BigInt @map("product_id")
  sortOrder    Int    @default(0) @map("sort_order")

  collection StorefrontCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    PosProduct           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([productId])
  @@map("storefront_collection_products")
}

/// Blog / news article for storefront (merchant-managed; optional public rendering later).
model StorefrontBlogPost {
  id               BigInt    @id @default(autoincrement())
  organizationId   BigInt    @map("organization_id")
  websiteId        BigInt?   @map("website_id")
  slug             String
  title            String
  excerpt          String?   @db.Text
  bodyHtml         String    @default("") @map("body_html") @db.Text
  featuredImageUrl String?   @map("featured_image_url")
  category         String?
  status           String    @default("draft") // draft | published | archived
  publishedAt      DateTime? @map("published_at")
  seoTitle         String?   @map("seo_title") @db.VarChar(512)
  seoDescription   String?   @map("seo_description") @db.Text
  sortOrder        Int       @default(0) @map("sort_order")
  isFeaturedHome   Boolean   @default(false) @map("is_featured_home")
  createdById      BigInt?   @map("created_by_id")
  updatedById      BigInt?   @map("updated_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  organization User     @relation("SfBlogPostOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  createdBy    User?    @relation("SfBlogPostCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?    @relation("SfBlogPostUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  comments     StorefrontBlogComment[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([websiteId])
  @@index([organizationId, publishedAt])
  @@map("storefront_blog_posts")
}

/// Reader comments on a published storefront blog post (moderated: pending → approved).
model StorefrontBlogComment {
  id          BigInt   @id @default(autoincrement())
  blogPostId  BigInt   @map("blog_post_id")
  authorName  String   @map("author_name") @db.VarChar(160)
  body        String   @db.Text
  status      String   @default("pending") // pending | approved | rejected | spam
  createdAt   DateTime @default(now()) @map("created_at")

  blogPost StorefrontBlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([blogPostId, status])
  @@index([blogPostId, createdAt])
  @@map("storefront_blog_comments")
}

/// Custom hostname / domain bound to a website (SSL + routing).
model Domain {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  websiteId      BigInt    @map("website_id")
  hostname       String
  status         String    @default("pending") // pending | active | error | disabled
  isPrimary      Boolean   @default(false) @map("is_primary")
  verifiedAt     DateTime? @map("verified_at")
  metadata       Json?
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User    @relation("SfDomainOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdBy    User?   @relation("SfDomainCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?   @relation("SfDomainUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([hostname])
  @@index([organizationId])
  @@index([websiteId])
  @@index([websiteId, status])
  @@index([hostname, status])
  @@map("storefront_domains")
}

/// Installable theme preset (global when organizationId is null).
model ThemeTemplate {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt?   @map("organization_id")
  name           String
  slug           String
  description    String?   @db.Text
  status         String    @default("active") // active | deprecated | archived
  previewUrl     String?   @map("preview_url")
  metadata       Json?
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User?   @relation("SfThemeTemplateOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?   @relation("SfThemeTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?   @relation("SfThemeTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  themes       Theme[]

  @@index([organizationId])
  @@index([organizationId, slug])
  @@index([organizationId, status])
  @@index([slug])
  @@index([status])
  @@map("storefront_theme_templates")
}

/// Live theme for a tenant; optional website scope and optional source template.
model Theme {
  id               BigInt    @id @default(autoincrement())
  organizationId   BigInt    @map("organization_id")
  websiteId        BigInt?   @map("website_id")
  sourceTemplateId BigInt?   @map("source_template_id")
  name             String
  slug             String
  status           String    @default("draft") // draft | active | archived
  metadata         Json?
  createdById      BigInt?   @map("created_by_id")
  updatedById      BigInt?   @map("updated_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  organization   User           @relation("SfThemeOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website        Website?       @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  sourceTemplate ThemeTemplate? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  createdBy      User?          @relation("SfThemeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?          @relation("SfThemeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  versions ThemeVersion[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([websiteId])
  @@index([websiteId, status])
  @@index([organizationId, status])
  @@index([slug])
  @@map("storefront_themes")
}

/// Immutable-ish snapshot of a theme (sections/blocks/tokens hang off this).
model ThemeVersion {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  themeId        BigInt    @map("theme_id")
  version        Int       @default(1)
  label          String?
  status         String    @default("draft") // draft | published | archived
  publishedAt    DateTime? @map("published_at")
  metadata       Json?
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization       User                     @relation("SfThemeVersionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  theme              Theme                    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  createdBy          User?                    @relation("SfThemeVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?                    @relation("SfThemeVersionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sectionDefinitions ThemeSectionDefinition[]
  styleTokens        ThemeStyleToken[]

  @@unique([themeId, version])
  @@index([organizationId])
  @@index([themeId])
  @@index([organizationId, status])
  @@index([themeId, status])
  @@index([status])
  @@map("storefront_theme_versions")
}

/// Section slot definition inside a theme version (layout blueprint).
model ThemeSectionDefinition {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  themeVersionId BigInt    @map("theme_version_id")
  key            String
  label          String?
  sortOrder      Int       @default(0) @map("sort_order")
  settings       Json?
  createdById    BigInt?   @map("created_by_id")
  updatedById  BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User               @relation("SfThemeSectionDefOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  themeVersion ThemeVersion       @relation(fields: [themeVersionId], references: [id], onDelete: Cascade)
  createdBy    User?              @relation("SfThemeSectionDefCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?              @relation("SfThemeSectionDefUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  blocks       ThemeBlockDefinition[]
  instances    SectionInstance[]

  @@index([organizationId])
  @@index([themeVersionId])
  @@index([organizationId, themeVersionId])
  @@index([themeVersionId, key])
  @@map("storefront_theme_section_definitions")
}

/// Block type definition within a section (theme version).
model ThemeBlockDefinition {
  id                BigInt    @id @default(autoincrement())
  organizationId    BigInt    @map("organization_id")
  themeSectionDefId BigInt    @map("theme_section_def_id")
  key               String
  blockType         String    @map("block_type")
  sortOrder         Int       @default(0) @map("sort_order")
  defaultProps      Json?     @map("default_props")
  schema            Json?
  createdById       BigInt?   @map("created_by_id")
  updatedById       BigInt?   @map("updated_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @map("updated_at")

  organization User                   @relation("SfThemeBlockDefOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  section      ThemeSectionDefinition @relation(fields: [themeSectionDefId], references: [id], onDelete: Cascade)
  createdBy    User?                  @relation("SfThemeBlockDefCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?                  @relation("SfThemeBlockDefUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  instances    BlockInstance[]

  @@index([organizationId])
  @@index([themeSectionDefId])
  @@index([organizationId, themeSectionDefId])
  @@index([themeSectionDefId, key])
  @@map("storefront_theme_block_definitions")
}

/// Design tokens for a theme version (CSS variables / theme JSON).
model ThemeStyleToken {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  themeVersionId BigInt    @map("theme_version_id")
  tokenKey       String    @map("token_key")
  value          String    @db.Text
  groupName      String?   @map("group_name")
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User         @relation("SfThemeStyleTokenOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  themeVersion ThemeVersion @relation(fields: [themeVersionId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("SfThemeStyleTokenCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("SfThemeStyleTokenUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([themeVersionId])
  @@index([organizationId, themeVersionId])
  @@index([themeVersionId, tokenKey])
  @@map("storefront_theme_style_tokens")
}

/// Storefront page (URL path); not the same as CustomPage (global CMS).
model Page {
  id            BigInt    @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  websiteId     BigInt    @map("website_id")
  slug          String
  title         String
  status        String    @default("draft") // draft | published | archived
  metadata      Json?
  createdById   BigInt?   @map("created_by_id")
  updatedById   BigInt?   @map("updated_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  organization User    @relation("SfPageOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdBy    User?   @relation("SfPageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?   @relation("SfPageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  versions PageVersion[]

  @@unique([websiteId, slug])
  @@index([organizationId])
  @@index([websiteId])
  @@index([websiteId, status])
  @@index([organizationId, status])
  @@index([slug])
  @@map("storefront_pages")
}

/// Versioned content snapshot for a storefront page.
model PageVersion {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  pageId         BigInt    @map("page_id")
  version        Int       @default(1)
  label          String?
  status         String    @default("draft") // draft | published | archived
  seoTitle       String?   @map("seo_title")
  seoDescription String?   @map("seo_description") @db.Text
  publishedAt    DateTime? @map("published_at")
  metadata       Json?
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User             @relation("SfPageVersionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  page         Page             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("SfPageVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?            @relation("SfPageVersionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sections     SectionInstance[]

  @@unique([pageId, version])
  @@index([organizationId])
  @@index([pageId])
  @@index([organizationId, status])
  @@index([pageId, status])
  @@index([status])
  @@map("storefront_page_versions")
}

/// Placed section on a page version (instances theme section definitions).
model SectionInstance {
  id                       BigInt    @id @default(autoincrement())
  organizationId           BigInt    @map("organization_id")
  pageVersionId            BigInt    @map("page_version_id")
  themeSectionDefinitionId BigInt?   @map("theme_section_definition_id")
  instanceKey              String?   @map("instance_key")
  sortOrder                Int       @default(0) @map("sort_order")
  status                   String    @default("active") // active | hidden | archived
  settings                 Json?
  createdById              BigInt?   @map("created_by_id")
  updatedById              BigInt?   @map("updated_by_id")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime? @map("updated_at")

  organization           User                    @relation("SfSectionInstanceOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  pageVersion            PageVersion             @relation(fields: [pageVersionId], references: [id], onDelete: Cascade)
  themeSectionDefinition ThemeSectionDefinition? @relation(fields: [themeSectionDefinitionId], references: [id], onDelete: SetNull)
  createdBy              User?                   @relation("SfSectionInstanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy              User?                   @relation("SfSectionInstanceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  blocks                 BlockInstance[]

  @@index([organizationId])
  @@index([pageVersionId])
  @@index([organizationId, status])
  @@index([pageVersionId, status])
  @@index([themeSectionDefinitionId])
  @@map("storefront_section_instances")
}

/// Content block inside a section instance.
model BlockInstance {
  id                       BigInt    @id @default(autoincrement())
  organizationId           BigInt    @map("organization_id")
  sectionInstanceId        BigInt    @map("section_instance_id")
  themeBlockDefinitionId   BigInt?   @map("theme_block_definition_id")
  sortOrder                Int       @default(0) @map("sort_order")
  status                   String    @default("active") // active | hidden | archived
  data                     Json?
  createdById              BigInt?   @map("created_by_id")
  updatedById              BigInt?   @map("updated_by_id")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime? @map("updated_at")

  organization           User                   @relation("SfBlockInstanceOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  sectionInstance        SectionInstance        @relation(fields: [sectionInstanceId], references: [id], onDelete: Cascade)
  themeBlockDefinition   ThemeBlockDefinition?  @relation(fields: [themeBlockDefinitionId], references: [id], onDelete: SetNull)
  createdBy              User?                  @relation("SfBlockInstanceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy              User?                  @relation("SfBlockInstanceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([sectionInstanceId])
  @@index([organizationId, status])
  @@index([sectionInstanceId, status])
  @@index([themeBlockDefinitionId])
  @@map("storefront_block_instances")
}

/// Tenant-scoped notification template for storefront (separate from Notification + NotificationTemplateLang CMS rows).
model NotificationTemplate {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  websiteId      BigInt?   @map("website_id")
  key            String
  channel        String    @default("email") // email | sms | push | in_app
  name           String?
  subject        String?
  body           String?   @db.Text
  variables      Json?
  status         String    @default("active") // active | archived
  metadata       Json?
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User     @relation("SfNotificationTemplateOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  createdBy    User?    @relation("SfNotifTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?    @relation("SfNotifTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  logs         NotificationLog[]

  @@unique([organizationId, websiteId, key, channel])
  @@index([organizationId])
  @@index([websiteId])
  @@index([organizationId, status])
  @@index([websiteId, status])
  @@index([key])
  @@map("storefront_notification_templates")
}

/// Delivery attempt log for storefront notifications.
model NotificationLog {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  websiteId      BigInt?   @map("website_id")
  templateId     BigInt?   @map("template_id")
  channel        String
  recipient      String?
  status         String    @default("queued") // queued | sent | failed | bounced
  payload        Json?
  errorMessage   String?   @map("error_message") @db.Text
  sentAt         DateTime? @map("sent_at")
  createdById    BigInt?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User                 @relation("SfNotificationLogOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website?             @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  template     NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy    User?                @relation("SfNotifLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([websiteId])
  @@index([templateId])
  @@index([organizationId, status])
  @@index([websiteId, status])
  @@index([status])
  @@map("storefront_notification_logs")
}

/// Auditable storefront / builder events (publish, domain verify, etc.).
model EventLog {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  websiteId      BigInt?   @map("website_id")
  eventType      String    @map("event_type")
  severity       String    @default("info") // info | warning | error
  actorUserId    BigInt?   @map("actor_user_id")
  resourceType   String?   @map("resource_type")
  resourceId     String?   @map("resource_id")
  message        String?   @db.Text
  metadata       Json?
  status         String    @default("recorded") // recorded | needs_review
  createdById    BigInt?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User     @relation("SfEventLogOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  actorUser    User?    @relation("SfEventLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdBy    User?    @relation("SfEventLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([websiteId])
  @@index([organizationId, eventType])
  @@index([websiteId, eventType])
  @@index([organizationId, status])
  @@index([status])
  @@index([createdAt])
  @@map("storefront_event_logs")
}

// ─── Storefront end-customer auth (separate from staff cookies / users.type staff) ───

/// B2C shopper for a specific website; not the accounting `Customer` (CRM) row unless linked.
model StorefrontCustomer {
  id                     BigInt    @id @default(autoincrement())
  organizationId         BigInt    @map("organization_id")
  websiteId              BigInt    @map("website_id")
  email                  String
  password               String
  name                   String?
  phone                  String?   @map("phone")
  savedAddresses         Json?     @map("saved_addresses")
  status                 String    @default("active") // active | suspended
  emailVerifiedAt        DateTime? @map("email_verified_at")
  /// When set, this storefront login is explicitly tied to a `users` row (staff/B2B bridge).
  linkedUserId           BigInt?   @map("linked_user_id")
  /// Optional link to accounting CRM `customers` for orders / invoicing later.
  accountingCustomerId   BigInt?   @map("accounting_customer_id")
  resetTokenHash         String?   @map("reset_token_hash")
  resetTokenExpires      DateTime? @map("reset_token_expires")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime? @map("updated_at")

  organization         User      @relation("SfCustomerOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website              Website   @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  linkedUser           User?     @relation("SfCustomerLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  accountingCustomer   Customer? @relation(fields: [accountingCustomerId], references: [id], onDelete: SetNull)
  sessions             StorefrontCustomerSession[]
  carts                StorefrontCart[]
  orders               StorefrontOrder[]
  supportTickets       StTicket[]

  @@unique([websiteId, email])
  @@index([organizationId])
  @@index([websiteId])
  @@index([organizationId, status])
  @@index([websiteId, status])
  @@index([email])
  @@map("storefront_customers")
}

/// Opaque server-side session for `sfc_session` cookie (staff uses `pf_*` only).
model StorefrontCustomerSession {
  id         BigInt   @id @default(autoincrement())
  customerId BigInt   @map("customer_id")
  tokenHash  String   @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  userAgent  String?  @map("user_agent") @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  customer StorefrontCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([customerId])
  @@index([expiresAt])
  @@map("storefront_customer_sessions")
}

// ─── Storefront commerce: cart + orders (Days 25–30) — separate from SaaS `Order` and POS `PosSale` ───

model StorefrontCart {
  id             String   @id @default(uuid())
  organizationId BigInt   @map("organization_id")
  websiteId      BigInt   @map("website_id")
  guestToken     String?  @map("guest_token")
  customerId     BigInt?  @map("customer_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization User                 @relation("SfCartOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website              @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  customer     StorefrontCustomer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines        StorefrontCartLine[]
  checkoutSessions StorefrontCheckoutSession[]

  @@index([organizationId, websiteId])
  @@index([guestToken])
  @@index([customerId])
  @@map("storefront_carts")
}

model StorefrontCartLine {
  id         BigInt   @id @default(autoincrement())
  cartId     String   @map("cart_id")
  productId  BigInt   @map("product_id")
  variantKey String   @default("") @map("variant_key")
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(15, 4) @map("unit_price")

  cart    StorefrontCart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product PosProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantKey])
  @@index([productId])
  @@map("storefront_cart_lines")
}

model StorefrontOrder {
  id                      BigInt    @id @default(autoincrement())
  organizationId          BigInt    @map("organization_id")
  websiteId               BigInt    @map("website_id")
  orderNumber             String    @unique @map("order_number")
  source                  String    @default("storefront")
  status                  String    @default("pending_payment")
  paymentStatus           String?   @map("payment_status")
  stripePaymentIntentId   String?   @map("stripe_payment_intent_id")
  stripeCheckoutSessionId String?   @map("stripe_checkout_session_id")
  subtotal                Decimal   @db.Decimal(15, 4)
  taxTotal                Decimal   @default(0) @db.Decimal(15, 4) @map("tax_total")
  shippingTotal           Decimal   @default(0) @db.Decimal(15, 4) @map("shipping_total")
  discountTotal           Decimal   @default(0) @db.Decimal(15, 4) @map("discount_total")
  total                   Decimal   @db.Decimal(15, 4)
  currency                String    @default("USD")
  customerEmail           String?   @map("customer_email")
  customerName            String?   @map("customer_name")
  shippingAddress         Json?     @map("shipping_address")
  billingAddress          Json?     @map("billing_address")
  storefrontCustomerId    BigInt?   @map("storefront_customer_id")
  internalNotes           String?   @db.Text @map("internal_notes")
  fulfillmentStatus       String    @default("unfulfilled") @map("fulfillment_status")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  paidAt                  DateTime? @map("paid_at")
  /// Optional link to the checkout session that created this order (Days 26–29).
  checkoutSessionId       String?   @map("checkout_session_id")
  /// Optional CRM accounting customer (Day 36–39).
  crmCustomerId           BigInt?   @map("crm_customer_id")
  discountCodeId          BigInt?   @map("discount_code_id")
  taxLines                Json?     @map("tax_lines")
  /// Linked `revenues` row after commerce→accounting sync (Days 46–48).
  accountingRevenueId     BigInt?   @unique @map("accounting_revenue_id")
  fulfillmentAssigneeUserId BigInt? @map("fulfillment_assignee_user_id")

  organization         User                  @relation("SfOrderOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website                Website               @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  storefrontCustomer     StorefrontCustomer?   @relation(fields: [storefrontCustomerId], references: [id], onDelete: SetNull)
  crmCustomer            Customer?             @relation(fields: [crmCustomerId], references: [id], onDelete: SetNull)
  discountCode           StorefrontDiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  accountingRevenue      Revenue?              @relation(fields: [accountingRevenueId], references: [id], onDelete: SetNull)
  fulfillmentAssignee    User?                 @relation("SfOrderFulfillmentAssignee", fields: [fulfillmentAssigneeUserId], references: [id], onDelete: SetNull)
  lines                  StorefrontOrderLine[]
  events                 StorefrontOrderEvent[]
  paymentRecords         StorefrontPaymentRecord[]
  shipments              StorefrontShipment[]
  discountRedemptions    StorefrontDiscountRedemption[]
  supportTickets         StTicket[]
  lmsEnrollments         Enrollment[]
  lmsStudentSubscriptions LmsStudentSubscription[]
  lmsCourseRevenueRecords LmsCourseRevenueRecord[]

  @@index([organizationId, websiteId])
  @@index([organizationId, status])
  @@index([crmCustomerId])
  @@index([discountCodeId])
  @@index([fulfillmentAssigneeUserId])
  @@map("storefront_orders")
}

model StorefrontOrderLine {
  id        BigInt   @id @default(autoincrement())
  orderId   BigInt   @map("order_id")
  productId BigInt?  @map("product_id")
  variantKey String @default("") @map("variant_key")
  name      String
  sku       String?
  quantity  Int
  unitPrice Decimal  @db.Decimal(15, 4) @map("unit_price")
  lineTotal Decimal  @db.Decimal(15, 4) @map("line_total")

  order   StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product PosProduct?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("storefront_order_lines")
}

model StorefrontOrderEvent {
  id        BigInt   @id @default(autoincrement())
  orderId   BigInt   @map("order_id")
  kind      String
  message   String?  @db.Text
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  order StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("storefront_order_events")
}

/// Server-side checkout state before payment (Day 26): shipping/tax lines, Stripe PI, stock holds.
model StorefrontCheckoutSession {
  id                   String   @id @default(uuid())
  organizationId       BigInt   @map("organization_id")
  websiteId            BigInt   @map("website_id")
  cartId               String   @map("cart_id")
  status               String   @default("open")
  expiresAt            DateTime @map("expires_at")
  shippingMethodKey    String?  @map("shipping_method_key")
  shippingAmount       Decimal  @default(0) @db.Decimal(15, 4) @map("shipping_amount")
  taxAmount            Decimal  @default(0) @db.Decimal(15, 4) @map("tax_amount")
  discountAmount       Decimal  @default(0) @db.Decimal(15, 4) @map("discount_amount")
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  metadata             Json?
  discountCodeId       BigInt?  @map("discount_code_id")

  organization User            @relation("SfCheckoutSessionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  cart         StorefrontCart  @relation(fields: [cartId], references: [id], onDelete: Cascade)
  discountCode StorefrontDiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)

  @@index([organizationId, websiteId])
  @@index([cartId])
  @@index([expiresAt])
  @@map("storefront_checkout_sessions")
}

/// Payment attempts for storefront orders (Day 26, 28) — separate from SaaS billing.
model StorefrontPaymentRecord {
  id                     BigInt    @id @default(autoincrement())
  orderId                BigInt    @map("order_id")
  provider               String    @default("stripe")
  amount                 Decimal   @db.Decimal(15, 4)
  currency               String    @default("USD")
  status                 String    @default("pending")
  stripePaymentIntentId  String?   @unique @map("stripe_payment_intent_id")
  idempotencyKey         String?   @map("idempotency_key")
  rawMetadata            Json?     @map("raw_metadata")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime? @updatedAt @map("updated_at")

  order StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("storefront_payment_records")
}

/// Fulfillment shipment row (Day 26).
model StorefrontShipment {
  id              BigInt    @id @default(autoincrement())
  orderId         BigInt    @map("order_id")
  status          String    @default("pending")
  carrier         String?   @db.VarChar(128)
  trackingNumber  String? @map("tracking_number") @db.VarChar(128)
  shippedAt       DateTime? @map("shipped_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  order StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("storefront_shipments")
}

/// Short-lived stock holds during checkout (Day 22).
model StorefrontStockReservation {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt @map("organization_id")
  productId      BigInt   @map("product_id")
  variantKey     String   @default("") @map("variant_key")
  quantity       Int
  cartId         String?  @map("cart_id")
  checkoutSessionId String? @map("checkout_session_id")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization User       @relation("SfStockReservationOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  product      PosProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId])
  @@index([expiresAt])
  @@index([cartId])
  @@map("storefront_stock_reservations")
}

// ─── Days 31–33: discounts, shipping zones, tax rules ───────────────────────

model StorefrontDiscountRule {
  id               BigInt    @id @default(autoincrement())
  organizationId   BigInt    @map("organization_id")
  websiteId        BigInt?   @map("website_id")
  name             String
  scope            String    @default("order")
  kind             String
  value            Decimal   @db.Decimal(15, 4)
  startsAt         DateTime? @map("starts_at")
  endsAt           DateTime? @map("ends_at")
  maxUses          Int?      @map("max_uses")
  perCustomerLimit Int?      @map("per_customer_limit")
  productIds       Json?     @map("product_ids")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  organization User     @relation("SfDiscountRuleOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  codes        StorefrontDiscountCode[]

  @@index([organizationId])
  @@index([websiteId])
  @@map("storefront_discount_rules")
}

model StorefrontDiscountCode {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  ruleId         BigInt   @map("rule_id")
  code           String
  usesCount      Int      @default(0) @map("uses_count")
  createdAt      DateTime @default(now()) @map("created_at")

  organization     User                       @relation("SfDiscountCodeOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  rule             StorefrontDiscountRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  redemptions      StorefrontDiscountRedemption[]
  orders           StorefrontOrder[]
  checkoutSessions StorefrontCheckoutSession[]

  @@unique([organizationId, code])
  @@index([ruleId])
  @@map("storefront_discount_codes")
}

model StorefrontDiscountRedemption {
  id        BigInt   @id @default(autoincrement())
  orderId   BigInt   @map("order_id")
  codeId    BigInt   @map("code_id")
  amount    Decimal  @db.Decimal(15, 4)
  createdAt DateTime @default(now()) @map("created_at")

  order StorefrontOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  code  StorefrontDiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([codeId])
  @@map("storefront_discount_redemptions")
}

model StorefrontShippingZone {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  websiteId      BigInt?  @map("website_id")
  name           String
  countries      Json
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User     @relation("SfShippingZoneOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  methods      StorefrontShippingMethod[]

  @@index([organizationId])
  @@index([websiteId])
  @@map("storefront_shipping_zones")
}

model StorefrontShippingMethod {
  id        BigInt   @id @default(autoincrement())
  zoneId    BigInt   @map("zone_id")
  name      String
  methodKey String   @map("method_key")
  flatRate  Decimal  @db.Decimal(15, 4) @map("flat_rate")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  zone StorefrontShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@unique([zoneId, methodKey])
  @@map("storefront_shipping_methods")
}

model StorefrontTaxRule {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  websiteId      BigInt?  @map("website_id")
  country        String   @db.VarChar(2)
  region         String?  @db.VarChar(64)
  ratePercent    Decimal  @db.Decimal(10, 4) @map("rate_percent")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User     @relation("SfTaxRuleOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: SetNull)

  @@index([organizationId, country])
  @@map("storefront_tax_rules")
}

model StorefrontTaxSettings {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  websiteId      BigInt?  @map("website_id")
  priceMode      String   @default("exclusive") @map("price_mode")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User     @relation("SfTaxSettingsOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website? @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([websiteId])
  @@map("storefront_tax_settings")
}

/// Expense Management add-on — reports and line items (tenant = `organizationId` → company `users.id`).
model EmExpenseReport {
  id              BigInt    @id @default(autoincrement())
  organizationId  BigInt    @map("organization_id")
  reportNumber    String    @map("report_number")
  purpose         String?
  dateFrom        DateTime? @map("date_from") @db.Date
  dateTo          DateTime? @map("date_to") @db.Date
  status          String    @default("draft")
  currency        String    @default("USD")
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(14, 2)
  rejectionNote   String?   @map("rejection_note") @db.Text
  createdByUserId BigInt?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  organization User             @relation("EmReportOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  lines        EmExpenseLine[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@unique([organizationId, reportNumber])
  @@map("em_expense_reports")
}

model EmExpenseLine {
  id               BigInt    @id @default(autoincrement())
  reportId         BigInt?   @map("report_id")
  organizationId   BigInt    @map("organization_id")
  expenseDate      DateTime  @map("expense_date") @db.Date
  category         String
  merchant         String?
  amount           Decimal   @db.Decimal(14, 2)
  currency         String    @default("USD")
  amountUsd        Decimal?  @map("amount_usd") @db.Decimal(14, 2)
  projectId        String?   @map("project_id")
  receiptAttached  Boolean   @default(false) @map("receipt_attached")
  billable         String?
  mileage          Decimal?  @db.Decimal(12, 2)
  ratePerMile      Decimal?  @map("rate_per_mile") @db.Decimal(12, 4)
  internalNote     String?   @map("internal_note")
  additionalInfo   String?   @map("additional_info") @db.Text
  department       String?
  status           String    @default("draft")
  createdByUserId  BigInt?   @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  report       EmExpenseReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  organization User             @relation("EmLineOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([reportId])
  @@index([organizationId, expenseDate])
  @@map("em_expense_lines")
}

/// Expense Management — per-organization category labels for expense lines.
model EmExpenseCategory {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User @relation("EmCategoryOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId, sortOrder])
  @@map("em_expense_categories")
}

/// Expense Management — internal notes on the operations workspace (per organization).
model EmWorkspaceNote {
  id              BigInt    @id @default(autoincrement())
  organizationId  BigInt    @map("organization_id")
  body            String    @db.Text
  createdByUserId BigInt?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  organization User  @relation("EmWorkspaceNoteOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User? @relation("EmWorkspaceNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("em_workspace_notes")
}

/// Expense Management — AAR/BI matter header and operation workspace settings (one row per org).
model EmWorkspaceContext {
  id                     BigInt    @id @default(autoincrement())
  organizationId         BigInt    @unique @map("organization_id")
  jsrNumber              String?   @map("jsr_number")
  aarStartDate           DateTime? @map("aar_start_date") @db.Date
  aarEndDate             DateTime? @map("aar_end_date") @db.Date
  matterNumber           String?   @map("matter_number")
  requestingDirector     String?   @map("requesting_director")
  clientName             String?   @map("client_name")
  requestingDepartment   String?   @map("requesting_department")
  receivingDepartment    String?   @map("receiving_department")
  aarLocation            String?   @map("aar_location") @db.Text
  billingPocName         String?   @map("billing_poc_name")
  billingPocEmail        String?   @map("billing_poc_email")
  clientPocName          String?   @map("client_poc_name")
  legacyClientId         String?   @map("legacy_client_id")
  d365ClientId           String?   @map("d365_client_id")
  operationStartDate     DateTime? @map("operation_start_date") @db.Date
  operationEndDate       DateTime? @map("operation_end_date") @db.Date
  tsheetsBased           Boolean   @default(false) @map("tsheets_based")
  aarRequired            Boolean   @default(false) @map("aar_required")
  costTransferMode       String    @default("default") @map("cost_transfer_mode")
  costTransferDefaultRate Decimal  @default(60) @map("cost_transfer_default_rate") @db.Decimal(12, 2)
  costTransferCustomRate  Decimal? @map("cost_transfer_custom_rate") @db.Decimal(12, 2)
  secondaryMatterNumber  String?   @map("secondary_matter_number")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime? @map("updated_at")

  organization User @relation("EmWorkspaceContextOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("em_workspace_context")
}

/// Expense Management — time sheet rows for the operations workspace.
model EmTimeEntry {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  employeeName   String    @map("employee_name")
  vendorName     String?   @map("vendor_name")
  serviceLine    String?   @map("service_line")
  clockInDate    DateTime  @map("clock_in_date") @db.Date
  clockInTime    String?   @map("clock_in_time")
  clockOutTime   String?   @map("clock_out_time")
  durationHours  Decimal?  @map("duration_hours") @db.Decimal(8, 2)
  billable       String?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User @relation("EmTimeEntryOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, clockInDate])
  @@map("em_time_entries")
}

/// Expense Management — cost adjustments on cost transfer screen.
model EmCostAdjustment {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  details        String    @db.Text
  attachmentUrl  String?   @map("attachment_url") @db.Text
  amount         Decimal?  @db.Decimal(14, 2)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User @relation("EmCostAdjustmentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("em_cost_adjustments")
}

/// Expense Management — documents attached to the operations workspace.
model EmWorkspaceDocument {
  id               BigInt    @id @default(autoincrement())
  organizationId   BigInt    @map("organization_id")
  title            String
  fileUrl          String    @map("file_url") @db.Text
  uploadedByUserId BigInt?   @map("uploaded_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  organization User  @relation("EmWorkspaceDocumentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User? @relation("EmWorkspaceDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("em_workspace_documents")
}

// ═══════════════════════════════════════════════════════════════════════════════
// LMS add-on — courses, sections, lessons, enrollments (organizationId → users.id)
// ═══════════════════════════════════════════════════════════════════════════════

/// Primary delivery mode for the course (lessons may still mix types per `CourseLesson.lessonType`).
enum LmsDeliveryType {
  VIDEO
  TEXT
  LIVE_CLASS
  PDF
}

enum LmsCourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum LmsEnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

/// How the learner seat was granted (free catalog, paid storefront, admin manual, comp).
enum LmsEnrollmentPurchaseKind {
  FREE
  PAID_STOREFRONT
  MANUAL
  COMPED
  SUBSCRIPTION
}

enum LmsStudentSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum LmsSubscriptionBillingPeriod {
  MONTHLY
  YEARLY
}

model CourseCategory {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  name           String    @db.VarChar(255)
  slug           String    @db.VarChar(255)
  description    String?   @db.Text
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User     @relation("LmsCourseCategoryOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  courses      Course[]

  @@unique([organizationId, slug])
  @@index([organizationId, sortOrder])
  @@map("lms_course_categories")
}

model CourseTag {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  name           String    @db.VarChar(255)
  slug           String    @db.VarChar(255)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User                @relation("LmsCourseTagOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  onCourses    CourseTagOnCourse[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("lms_course_tags")
}

/// Instructor directory entry for a user within one organization (links to `Course` via `CourseInstructor`).
model InstructorProfile {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  userId         BigInt    @map("user_id")
  displayName    String?   @map("display_name") @db.VarChar(255)
  headline       String?   @db.VarChar(512)
  bio            String?   @db.Text
  /// Public headshot or brand image URL for the instructor card (falls back to `users.avatar` in UI when null).
  avatarUrl      String?   @map("avatar_url") @db.VarChar(2048)
  /// JSON array of expertise labels, e.g. `["Data Science","Python"]`.
  expertise      Json?     @map("expertise")
  isActive       Boolean   @default(true) @map("is_active")
  /// Default commission rate (0–100) for courses without a per-assignment override.
  commissionPercent Decimal @default(0) @db.Decimal(5, 2) @map("commission_percent")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User               @relation("LmsInstructorProfileOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User               @relation("LmsInstructorProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  courseLinks  CourseInstructor[]
  commissions  LmsInstructorCommission[]
  payouts      LmsInstructorPayout[]

  @@unique([organizationId, userId])
  @@index([organizationId, isActive])
  @@map("lms_instructor_profiles")
}

model Course {
  id              BigInt          @id @default(autoincrement())
  organizationId  BigInt          @map("organization_id")
  categoryId      BigInt?         @map("category_id")
  title           String          @db.VarChar(512)
  slug            String          @db.VarChar(255)
  description     String?         @db.Text
  /// Primary modality: on-demand video, text-based, or live-class-led offering.
  deliveryType    LmsDeliveryType @map("delivery_type")
  isPublic        Boolean         @default(false) @map("is_public")
  /// Maximum active enrollments; null means unlimited.
  capacity        Int?            @map("capacity")
  /// Default access window for new enrollments (can be overridden on `Enrollment`).
  accessStartsAt  DateTime?       @map("access_starts_at")
  accessEndsAt    DateTime?       @map("access_ends_at")
  status          LmsCourseStatus @default(DRAFT)
  /// Hero / card image from the media library (path or URL).
  coverImageUrl   String?         @map("cover_image_url") @db.VarChar(2048)
  /// Optional course promo / trailer embed (YouTube, Vimeo, or iframe src URL).
  videoEmbedUrl   String?         @map("video_embed_url") @db.VarChar(2048)
  /// Optional course-level PDF document (path or HTTPS URL).
  pdfDocumentUrl  String?         @map("pdf_document_url") @db.VarChar(2048)
  /// Direct list price when not using a linked POS product.
  salePrice       Decimal?        @map("sale_price") @db.Decimal(15, 4)
  saleCurrency    String          @default("USD") @map("sale_currency") @db.VarChar(3)
  /// Optional link to `pos_products` for catalog + storefront checkout pricing.
  linkedPosProductId BigInt?      @map("linked_pos_product_id")
  createdById     BigInt?         @map("created_by_id")
  updatedById     BigInt?         @map("updated_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime?       @map("updated_at")

  organization User               @relation("LmsCourseOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  category     CourseCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  linkedPosProduct PosProduct?    @relation("LmsCourseLinkedProduct", fields: [linkedPosProductId], references: [id], onDelete: SetNull)
  createdBy    User?              @relation("LmsCourseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?              @relation("LmsCourseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  sections     CourseSection[]
  lessons      CourseLesson[]
  enrollments  Enrollment[]
  tagLinks     CourseTagOnCourse[]
  instructors  CourseInstructor[]
  liveSessions LmsLiveSession[]
  subscriptionPlanCourses LmsSubscriptionPlanCourse[]
  revenueRecords          LmsCourseRevenueRecord[]
  instructorCommissions   LmsInstructorCommission[]
  reviews                 LmsCourseReview[]
  supportTickets          StTicket[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, isPublic])
  @@index([categoryId])
  @@index([linkedPosProductId])
  @@map("lms_courses")
}

model CourseSection {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  courseId       BigInt    @map("course_id")
  title          String    @db.VarChar(512)
  description    String?   @db.Text
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User           @relation("LmsCourseSectionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons      CourseLesson[]

  @@index([organizationId])
  @@index([courseId, sortOrder])
  @@map("lms_course_sections")
}

model CourseLesson {
  id               BigInt          @id @default(autoincrement())
  organizationId   BigInt          @map("organization_id")
  courseId         BigInt          @map("course_id")
  sectionId        BigInt          @map("section_id")
  title            String          @db.VarChar(512)
  lessonType       LmsDeliveryType @map("lesson_type")
  bodyText         String?         @map("body_text") @db.Text
  videoUrl         String?         @map("video_url") @db.VarChar(2048)
  videoMetadata    Json?           @map("video_metadata")
  liveStartsAt     DateTime?       @map("live_starts_at")
  liveEndsAt       DateTime?       @map("live_ends_at")
  externalLiveUrl  String?         @map("external_live_url") @db.VarChar(2048)
  durationSeconds  Int?            @map("duration_seconds")
  sortOrder        Int             @default(0) @map("sort_order")
  isPublished      Boolean         @default(false) @map("is_published")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime?       @map("updated_at")

  organization User          @relation("LmsCourseLessonOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  section      CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lmsLessonProgress LmsLessonProgress[]
  liveSessions LmsLiveSession[]
  supportTickets StTicket[]

  @@index([organizationId])
  @@index([courseId])
  @@index([sectionId, sortOrder])
  @@map("lms_course_lessons")
}

/// Student (or `users` row) enrolled in a course; optional assigned instructor at enrollment level.
model Enrollment {
  id                 BigInt                     @id @default(autoincrement())
  organizationId     BigInt                     @map("organization_id")
  courseId           BigInt                     @map("course_id")
  studentUserId      BigInt                     @map("student_user_id")
  instructorUserId   BigInt?                    @map("instructor_user_id")
  status               LmsEnrollmentStatus        @default(ACTIVE)
  /// When the seat came from storefront checkout, links the paid `storefront_orders` row.
  storefrontOrderId    BigInt?                    @map("storefront_order_id")
  /// When access is granted via an LMS subscription bundle.
  studentSubscriptionId BigInt?                   @map("student_subscription_id")
  /// Accounting CRM contact (`customers`) tied to this enrollment (often same as the order’s CRM row).
  crmCustomerId        BigInt?                    @map("crm_customer_id")
  purchaseKind         LmsEnrollmentPurchaseKind? @map("purchase_kind")
  enrolledAt         DateTime                   @default(now()) @map("enrolled_at")
  accessStartsAt     DateTime?                  @map("access_starts_at")
  accessEndsAt       DateTime?                  @map("access_ends_at")
  completedAt        DateTime?                  @map("completed_at")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime?                  @map("updated_at")

  organization     User             @relation("LmsEnrollmentOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student          User             @relation("LmsEnrollmentStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  instructor       User?            @relation("LmsEnrollmentInstructorUser", fields: [instructorUserId], references: [id], onDelete: SetNull)
  storefrontOrder  StorefrontOrder? @relation(fields: [storefrontOrderId], references: [id], onDelete: SetNull)
  studentSubscription LmsStudentSubscription? @relation(fields: [studentSubscriptionId], references: [id], onDelete: SetNull)
  crmCustomer      Customer?        @relation(fields: [crmCustomerId], references: [id], onDelete: SetNull)
  lessonProgress   LmsLessonProgress[]
  liveAttendance   LmsLiveAttendance[]
  revenueRecords   LmsCourseRevenueRecord[]
  reviews          LmsCourseReview[]

  @@unique([courseId, studentUserId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([studentUserId])
  @@index([instructorUserId])
  @@index([storefrontOrderId])
  @@index([crmCustomerId])
  @@index([studentSubscriptionId])
  @@map("lms_enrollments")
}

/// Org-scoped learner subscription catalog (mirrors SaaS `plans` pricing shape).
model LmsSubscriptionPlan {
  id                   BigInt   @id @default(autoincrement())
  organizationId       BigInt   @map("organization_id")
  name                 String   @db.VarChar(255)
  description          String?  @db.Text
  status               Boolean  @default(true)
  freePlan             Boolean  @default(false) @map("free_plan")
  packagePriceMonthly  Decimal  @default(0) @db.Decimal(10, 2) @map("package_price_monthly")
  packagePriceYearly   Decimal  @default(0) @db.Decimal(10, 2) @map("package_price_yearly")
  trial                Boolean  @default(false)
  trialDays            Int      @default(0) @map("trial_days")
  /// Optional POS product for storefront checkout of the whole bundle.
  linkedPosProductId   BigInt?  @map("linked_pos_product_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime? @map("updated_at")

  organization     User                        @relation("LmsSubscriptionPlanOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  linkedPosProduct PosProduct?                 @relation("LmsSubscriptionPlanLinkedProduct", fields: [linkedPosProductId], references: [id], onDelete: SetNull)
  planCourses      LmsSubscriptionPlanCourse[]
  subscriptions    LmsStudentSubscription[]

  @@index([organizationId, status])
  @@index([linkedPosProductId])
  @@map("lms_subscription_plans")
}

/// Courses included in a subscription bundle.
model LmsSubscriptionPlanCourse {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  planId         BigInt   @map("plan_id")
  courseId       BigInt   @map("course_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization User                @relation("LmsSubscriptionPlanCourseOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  plan         LmsSubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  course       Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([planId, courseId])
  @@index([organizationId])
  @@index([courseId])
  @@map("lms_subscription_plan_courses")
}

/// A learner’s active (or historical) subscription to an LMS plan.
model LmsStudentSubscription {
  id                 BigInt                       @id @default(autoincrement())
  organizationId     BigInt                       @map("organization_id")
  planId             BigInt                       @map("plan_id")
  studentUserId      BigInt                       @map("student_user_id")
  status             LmsStudentSubscriptionStatus @default(ACTIVE)
  billingPeriod      LmsSubscriptionBillingPeriod @map("billing_period")
  currentPeriodStart DateTime                     @map("current_period_start")
  currentPeriodEnd   DateTime                     @map("current_period_end")
  cancelledAt        DateTime?                    @map("cancelled_at")
  storefrontOrderId  BigInt?                      @map("storefront_order_id")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime?                    @map("updated_at")

  organization    User                 @relation("LmsStudentSubscriptionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  plan            LmsSubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  student         User                 @relation("LmsStudentSubscriptionStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  storefrontOrder StorefrontOrder?     @relation(fields: [storefrontOrderId], references: [id], onDelete: SetNull)
  enrollments     Enrollment[]

  @@index([organizationId, studentUserId, status])
  @@index([planId])
  @@index([storefrontOrderId])
  @@map("lms_student_subscriptions")
}

/// Per-enrollment lesson engagement for student dashboard progress and continue learning.
model LmsLessonProgress {
  id               BigInt    @id @default(autoincrement())
  organizationId   BigInt    @map("organization_id")
  enrollmentId     BigInt    @map("enrollment_id")
  lessonId         BigInt    @map("lesson_id")
  completedAt      DateTime? @map("completed_at")
  lastEngagedAt    DateTime  @default(now()) @map("last_engaged_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  organization User           @relation("LmsLessonProgressOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  enrollment   Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([organizationId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("lms_lesson_progress")
}

model CourseInstructor {
  id                   BigInt   @id @default(autoincrement())
  organizationId       BigInt   @map("organization_id")
  courseId             BigInt   @map("course_id")
  instructorProfileId  BigInt   @map("instructor_profile_id")
  role                 String?  @db.VarChar(64)
  isPrimary            Boolean  @default(false) @map("is_primary")
  /// Optional override of the instructor profile default commission %.
  commissionPercent    Decimal? @db.Decimal(5, 2) @map("commission_percent")
  createdAt            DateTime @default(now()) @map("created_at")

  organization       User              @relation("LmsCourseInstructorOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course             Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructorProfile  InstructorProfile @relation(fields: [instructorProfileId], references: [id], onDelete: Cascade)

  @@unique([courseId, instructorProfileId])
  @@index([organizationId])
  @@index([instructorProfileId])
  @@map("lms_course_instructors")
}

enum LmsCourseRevenueSource {
  STOREFRONT_ORDER
  SUBSCRIPTION_ORDER
  MANUAL
}

enum LmsInstructorCommissionStatus {
  ACCRUED
  PAYOUT_PENDING
  PAID
}

enum LmsInstructorPayoutStatus {
  DRAFT
  SCHEDULED
  PAID
  CANCELLED
}

/// Gross revenue attributed to a course (from paid orders, etc.).
model LmsCourseRevenueRecord {
  id                  BigInt                 @id @default(autoincrement())
  organizationId      BigInt                 @map("organization_id")
  courseId            BigInt                 @map("course_id")
  source              LmsCourseRevenueSource
  grossAmount         Decimal                @db.Decimal(15, 4) @map("gross_amount")
  currency            String                 @default("USD") @db.VarChar(3)
  storefrontOrderId   BigInt?                @map("storefront_order_id")
  enrollmentId        BigInt?                @map("enrollment_id")
  accountingRevenueId BigInt?                @map("accounting_revenue_id")
  recordedAt          DateTime               @default(now()) @map("recorded_at")
  createdAt           DateTime               @default(now()) @map("created_at")

  organization      User                      @relation("LmsCourseRevenueOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course            Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  storefrontOrder   StorefrontOrder?          @relation(fields: [storefrontOrderId], references: [id], onDelete: SetNull)
  enrollment        Enrollment?               @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  commissions       LmsInstructorCommission[]

  @@unique([storefrontOrderId, courseId])
  @@index([organizationId, courseId])
  @@index([recordedAt])
  @@map("lms_course_revenue_records")
}

/// Instructor commission accrual for a revenue record.
model LmsInstructorCommission {
  id                   BigInt                      @id @default(autoincrement())
  organizationId       BigInt                      @map("organization_id")
  instructorProfileId  BigInt                      @map("instructor_profile_id")
  courseId             BigInt                      @map("course_id")
  revenueRecordId      BigInt                      @map("revenue_record_id")
  commissionPercent    Decimal                     @db.Decimal(5, 2) @map("commission_percent")
  commissionAmount     Decimal                     @db.Decimal(15, 4) @map("commission_amount")
  currency             String                      @default("USD") @db.VarChar(3)
  status               LmsInstructorCommissionStatus @default(ACCRUED)
  accountingExpenseId  BigInt?                     @map("accounting_expense_id")
  payoutId             BigInt?                     @map("payout_id")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime?                   @map("updated_at")

  organization       User                 @relation("LmsInstructorCommissionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  instructorProfile  InstructorProfile    @relation(fields: [instructorProfileId], references: [id], onDelete: Cascade)
  course             Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  revenueRecord      LmsCourseRevenueRecord @relation(fields: [revenueRecordId], references: [id], onDelete: Cascade)
  payout             LmsInstructorPayout? @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@index([organizationId, instructorProfileId, status])
  @@index([courseId])
  @@index([revenueRecordId])
  @@index([payoutId])
  @@map("lms_instructor_commissions")
}

/// Payout batch placeholder (mark scheduled/paid without external payment rails).
model LmsInstructorPayout {
  id                  BigInt                  @id @default(autoincrement())
  organizationId      BigInt                  @map("organization_id")
  instructorProfileId BigInt                  @map("instructor_profile_id")
  totalAmount         Decimal                 @db.Decimal(15, 4) @map("total_amount")
  currency            String                  @default("USD") @db.VarChar(3)
  status              LmsInstructorPayoutStatus @default(DRAFT)
  periodStart         DateTime?               @map("period_start")
  periodEnd           DateTime?               @map("period_end")
  paidAt              DateTime?               @map("paid_at")
  notes               String?                 @db.Text
  accountingExpenseId BigInt?                 @map("accounting_expense_id")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime?               @map("updated_at")

  organization      User                      @relation("LmsInstructorPayoutOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  instructorProfile InstructorProfile         @relation(fields: [instructorProfileId], references: [id], onDelete: Cascade)
  commissions       LmsInstructorCommission[]

  @@index([organizationId, instructorProfileId, status])
  @@map("lms_instructor_payouts")
}

enum LmsCourseReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Learner rating + review text for a course (moderated before public display).
model LmsCourseReview {
  id              BigInt                @id @default(autoincrement())
  organizationId  BigInt                @map("organization_id")
  courseId        BigInt                @map("course_id")
  studentUserId   BigInt                @map("student_user_id")
  enrollmentId    BigInt?               @map("enrollment_id")
  rating          Int
  body            String                @db.Text
  status          LmsCourseReviewStatus @default(PENDING)
  moderatedById   BigInt?               @map("moderated_by_id")
  moderatedAt     DateTime?             @map("moderated_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime?             @map("updated_at")

  organization  User        @relation("LmsCourseReviewOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student       User        @relation("LmsCourseReviewStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  enrollment    Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  moderatedBy   User?       @relation("LmsCourseReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@unique([courseId, studentUserId])
  @@index([organizationId, courseId, status])
  @@index([studentUserId])
  @@map("lms_course_reviews")
}

model CourseTagOnCourse {
  organizationId BigInt @map("organization_id")
  courseId       BigInt @map("course_id")
  tagId          BigInt @map("tag_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization User      @relation("LmsCourseTagOnCourseOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  course       Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag          CourseTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@index([organizationId])
  @@index([tagId])
  @@map("lms_course_tag_on_course")
}

/// External meeting provider for a live session (link is stored manually until integrations ship).
enum LmsLiveMeetingProvider {
  ZOOM
  GOOGLE_MEET
  MICROSOFT_TEAMS
  OTHER
}

enum LmsLiveSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum LmsLiveAttendanceStatus {
  REGISTERED
  ATTENDED
  ABSENT
}

/// Scheduled live class attached to a course (optionally linked to a `CourseLesson`).
model LmsLiveSession {
  id              BigInt                   @id @default(autoincrement())
  organizationId  BigInt                   @map("organization_id")
  courseId        BigInt                   @map("course_id")
  courseLessonId  BigInt?                  @map("course_lesson_id")
  title           String                   @db.VarChar(512)
  description     String?                  @db.Text
  startsAt        DateTime                 @map("starts_at")
  endsAt          DateTime                 @map("ends_at")
  meetingProvider LmsLiveMeetingProvider   @default(OTHER) @map("meeting_provider")
  meetingUrl      String?                  @map("meeting_url") @db.VarChar(2048)
  /// Max learners with REGISTERED or ATTENDED status; null = unlimited.
  capacity        Int?                     @map("capacity")
  status          LmsLiveSessionStatus     @default(SCHEDULED)
  /// Google Calendar event id when synced via a connected admin/creator account.
  googleCalendarEventId String?            @map("google_calendar_event_id") @db.VarChar(256)
  createdById     BigInt?                  @map("created_by_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime?                @map("updated_at")

  organization User          @relation("LmsLiveSessionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  userCalendarLinks LmsUserCalendarEventLink[]
  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseLesson CourseLesson? @relation(fields: [courseLessonId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("LmsLiveSessionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  attendances  LmsLiveAttendance[]

  @@index([organizationId, startsAt])
  @@index([courseId, startsAt])
  @@index([courseLessonId])
  @@map("lms_live_sessions")
}

/// Per-enrollment attendance for a live session.
model LmsLiveAttendance {
  id             BigInt                  @id @default(autoincrement())
  organizationId BigInt                  @map("organization_id")
  sessionId      BigInt                  @map("session_id")
  enrollmentId   BigInt                  @map("enrollment_id")
  status         LmsLiveAttendanceStatus @default(REGISTERED)
  joinedAt       DateTime?               @map("joined_at")
  markedAt       DateTime?               @map("marked_at")
  markedById     BigInt?                 @map("marked_by_id")
  notes          String?                 @db.VarChar(512)
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime?               @map("updated_at")

  organization User         @relation("LmsLiveAttendanceOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  session      LmsLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  markedBy     User?        @relation("LmsLiveAttendanceMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)

  @@unique([sessionId, enrollmentId])
  @@index([organizationId])
  @@index([sessionId, status])
  @@index([enrollmentId])
  @@map("lms_live_attendance")
}

/// OAuth connection for pushing LMS live sessions to a user's Google Calendar.
model UserGoogleCalendarConnection {
  id                   BigInt    @id @default(autoincrement())
  userId               BigInt    @unique @map("user_id")
  organizationId       BigInt    @map("organization_id")
  googleEmail          String?   @map("google_email") @db.VarChar(320)
  refreshToken         String    @map("refresh_token") @db.Text
  accessToken          String?   @map("access_token") @db.Text
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  calendarId           String    @default("primary") @map("calendar_id") @db.VarChar(256)
  syncLiveSessions     Boolean   @default(true) @map("sync_live_sessions")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime? @map("updated_at")

  user         User @relation("UserGoogleCalendarConnection", fields: [userId], references: [id], onDelete: Cascade)
  organization User @relation("UserGoogleCalendarConnectionOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("user_google_calendar_connections")
}

/// Per-user Google Calendar event for an exported live session.
model LmsUserCalendarEventLink {
  id              BigInt   @id @default(autoincrement())
  userId          BigInt   @map("user_id")
  sessionId       BigInt   @map("session_id")
  googleEventId   String   @map("google_event_id") @db.VarChar(256)
  googleCalendarId String  @map("google_calendar_id") @db.VarChar(256)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  user    User           @relation("LmsUserCalendarEventLinkUser", fields: [userId], references: [id], onDelete: Cascade)
  session LmsLiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@map("lms_user_calendar_event_links")
}

/// Idempotent LMS notification dispatch log (email/SMS dedupe).
model LmsNotificationLog {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  templateKey    String   @map("template_key") @db.VarChar(128)
  channel        String   @db.VarChar(16)
  userId         BigInt?  @map("user_id")
  referenceType  String   @map("reference_type") @db.VarChar(64)
  referenceId    BigInt   @map("reference_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization User @relation("LmsNotificationLogOrganization", fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([templateKey, channel, referenceType, referenceId, userId])
  @@index([organizationId, templateKey])
  @@map("lms_notification_logs")
}

/// LMS training event category (tenant-scoped).
model LmsEventCategory {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  slug           String    @db.VarChar(128)
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  status         String    @default("published") @db.VarChar(32)
  sortOrder      Int       @default(0) @map("sort_order")
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User              @relation("LmsEventCategoryOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  events       LmsTrainingEvent[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("lms_event_categories")
}

/// Standalone LMS training / booking event (not HRM or storefront events).
model LmsTrainingEvent {
  id                    BigInt    @id @default(autoincrement())
  organizationId        BigInt    @map("organization_id")
  slug                  String    @db.VarChar(160)
  title                 String    @db.VarChar(512)
  description           String?   @db.Text
  shortDescription      String?   @map("short_description") @db.VarChar(512)
  imageUrl              String?   @map("image_url") @db.VarChar(2048)
  categoryId            BigInt?   @map("category_id")
  eventType             String    @map("event_type") @db.VarChar(64)
  deliveryMode          String    @map("delivery_mode") @db.VarChar(32)
  status                String    @default("draft") @db.VarChar(32)
  instructorName        String?   @map("instructor_name") @db.VarChar(255)
  instructorUserId      BigInt?   @map("instructor_user_id")
  startsAt              DateTime  @map("starts_at")
  endsAt                DateTime  @map("ends_at")
  timezone              String    @default("America/New_York") @db.VarChar(64)
  venueName             String?   @map("venue_name") @db.VarChar(255)
  venueAddress          String?   @map("venue_address") @db.VarChar(512)
  venueCity             String?   @map("venue_city") @db.VarChar(128)
  venueState            String?   @map("venue_state") @db.VarChar(64)
  venuePostalCode       String?   @map("venue_postal_code") @db.VarChar(32)
  venueCountry          String?   @map("venue_country") @db.VarChar(64)
  venueLat              Float?    @map("venue_lat")
  venueLng              Float?    @map("venue_lng")
  onlineMeetingUrl      String?   @map("online_meeting_url") @db.VarChar(2048)
  capacity              Int?
  registeredCount       Int       @default(0) @map("registered_count")
  isPublic              Boolean   @default(true) @map("is_public")
  isFree                Boolean   @default(false) @map("is_free")
  priceFrom             Decimal?  @map("price_from") @db.Decimal(12, 2)
  currency              String    @default("USD") @db.VarChar(3)
  certificationAvailable Boolean  @default(false) @map("certification_available")
  certificationName     String?   @map("certification_name") @db.VarChar(255)
  requirements          String?   @db.Text
  cancellationPolicy    String?   @map("cancellation_policy") @db.Text
  isFeatured            Boolean   @default(false) @map("is_featured")
  ageRule               String?   @map("age_rule") @db.VarChar(32)
  doorsOpen             String?   @map("doors_open") @db.VarChar(32)
  bingoStart            String?   @map("bingo_start") @db.VarChar(32)
  venueType             String?   @map("venue_type") @db.VarChar(64)
  cardsIncluded         Int?      @map("cards_included")
  extraCardPrice        Decimal?  @map("extra_card_price") @db.Decimal(12, 2)
  foodAndDrinks         String?   @map("food_and_drinks") @db.Text
  attire                String?   @db.VarChar(128)
  detailContent         Json?     @map("detail_content")
  linkedCourseId        BigInt?   @map("linked_course_id")
  linkedLiveSessionId   BigInt?   @map("linked_live_session_id")
  revenueTotal          Decimal   @default(0) @map("revenue_total") @db.Decimal(14, 2)
  createdById           BigInt?   @map("created_by_id")
  updatedById           BigInt?   @map("updated_by_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime? @map("updated_at")

  organization   User                   @relation("LmsTrainingEventOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  category       LmsEventCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tickets        LmsEventTicket[]
  registrations  LmsEventRegistration[]
  certificates   LmsEventCertificate[]
  transactions   LmsEventTransaction[]
  supportTickets LmsEventSupportTicket[]
  notifications  LmsEventNotification[]
  wishlistItems  LmsEventWishlistItem[]

  @@unique([organizationId, slug])
  @@index([organizationId, status, startsAt])
  @@map("lms_events")
}

model LmsEventTicket {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  eventId        BigInt    @map("event_id")
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  price          Decimal   @default(0) @db.Decimal(12, 2)
  currency       String    @default("USD") @db.VarChar(3)
  quantity       Int?
  soldCount      Int       @default(0) @map("sold_count")
  saleStartsAt   DateTime? @map("sale_starts_at")
  saleEndsAt     DateTime? @map("sale_ends_at")
  ticketStatus   String    @default("available") @map("ticket_status") @db.VarChar(32)
  isFree         Boolean   @default(false) @map("is_free")
  accessRules    String?   @map("access_rules") @db.Text
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  event          LmsTrainingEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations  LmsEventRegistration[]

  @@index([eventId])
  @@map("lms_event_tickets")
}

model LmsEventRegistration {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  eventId        BigInt    @map("event_id")
  ticketId       BigInt?   @map("ticket_id")
  studentUserId  BigInt    @map("student_user_id")
  bookingStatus  String    @default("pending") @map("booking_status") @db.VarChar(32)
  attendeeName   String    @map("attendee_name") @db.VarChar(255)
  attendeeEmail  String    @map("attendee_email") @db.VarChar(320)
  paymentStatus  String    @default("unpaid") @map("payment_status") @db.VarChar(32)
  amountPaid     Decimal   @default(0) @map("amount_paid") @db.Decimal(12, 2)
  currency       String    @default("USD") @db.VarChar(3)
  registeredAt   DateTime  @default(now()) @map("registered_at")
  checkedInAt    DateTime? @map("checked_in_at")
  qrToken        String    @map("qr_token") @db.VarChar(128)
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User              @relation("LmsEventRegistrationOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  student      User              @relation("LmsEventRegistrationStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  event        LmsTrainingEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket       LmsEventTicket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  certificate  LmsEventCertificate?
  transactions LmsEventTransaction[]

  @@unique([eventId, studentUserId])
  @@index([organizationId, studentUserId])
  @@map("lms_event_registrations")
}

model LmsEventCertificate {
  id                BigInt    @id @default(autoincrement())
  organizationId    BigInt    @map("organization_id")
  eventId           BigInt    @map("event_id")
  registrationId    BigInt    @unique @map("registration_id")
  studentUserId     BigInt    @map("student_user_id")
  studentName       String    @map("student_name") @db.VarChar(255)
  eventTitle        String    @map("event_title") @db.VarChar(512)
  certificateStatus String    @default("not_eligible") @map("certificate_status") @db.VarChar(32)
  issuedAt          DateTime? @map("issued_at")
  expiresAt         DateTime? @map("expires_at")
  renewalRequired   Boolean   @default(false) @map("renewal_required")
  templateId        String?   @map("template_id") @db.VarChar(64)
  downloadUrl       String?   @map("download_url") @db.VarChar(2048)
  createdById       BigInt?   @map("created_by_id")
  updatedById       BigInt?   @map("updated_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @map("updated_at")

  organization User                 @relation("LmsEventCertificateOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  student      User                 @relation("LmsEventCertificateStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  event        LmsTrainingEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration LmsEventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([organizationId, studentUserId])
  @@map("lms_event_certificates")
}

model LmsEventTransaction {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  eventId        BigInt   @map("event_id")
  registrationId BigInt   @map("registration_id")
  attendeeName   String   @map("attendee_name") @db.VarChar(255)
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD") @db.VarChar(3)
  method         String   @default("card") @db.VarChar(32)
  status         String   @default("completed") @db.VarChar(32)
  processedAt    DateTime @default(now()) @map("processed_at")
  createdById    BigInt?  @map("created_by_id")
  updatedById    BigInt?  @map("updated_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  event        LmsTrainingEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration LmsEventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([organizationId, eventId])
  @@map("lms_event_transactions")
}

model LmsEventSupportTicket {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  eventId        BigInt?   @map("event_id")
  registrationId BigInt?   @map("registration_id")
  studentUserId  BigInt    @map("student_user_id")
  subject        String    @db.VarChar(512)
  status         String    @default("open") @db.VarChar(32)
  priority       String    @default("normal") @db.VarChar(16)
  lastReplyAt    DateTime? @map("last_reply_at")
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User              @relation("LmsEventSupportTicketOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  student      User              @relation("LmsEventSupportTicketStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  event        LmsTrainingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId, studentUserId])
  @@map("lms_event_support_tickets")
}

model LmsEventNotification {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  userId         BigInt    @map("user_id")
  eventId        BigInt?   @map("event_id")
  kind           String    @db.VarChar(64)
  title          String    @db.VarChar(512)
  body           String    @db.Text
  readAt         DateTime? @map("read_at")
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User              @relation("LmsEventNotificationOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User              @relation("LmsEventNotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  event        LmsTrainingEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId, userId])
  @@map("lms_event_notifications")
}

model LmsEventWishlistItem {
  id             BigInt    @id @default(autoincrement())
  organizationId BigInt    @map("organization_id")
  eventId        BigInt    @map("event_id")
  studentUserId  BigInt    @map("student_user_id")
  createdById    BigInt?   @map("created_by_id")
  updatedById    BigInt?   @map("updated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  organization User             @relation("LmsEventWishlistOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  student      User             @relation("LmsEventWishlistStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
