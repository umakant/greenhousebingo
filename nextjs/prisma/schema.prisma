  createdBy   BigInt?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @map("updated_at")

  branch       HrmBranch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  designations HrmDesignation[]
  employees    HrmEmployee[]
  transfersFrom HrmTransfer[] @relation("TransferFromDept")
  transfersTo   HrmTransfer[] @relation("TransferToDept")

  @@index([branchId])
  @@index([createdBy])
  @@map("hrm_departments")
}

model HrmDesignation {
  id            BigInt    @id @default(autoincrement())
