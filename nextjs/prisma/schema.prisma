generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              BigInt    @id
  name            String?
  email           String?   @unique
  password        String?
  type            String?
  slug            String?   @map("slug")
  mobileNo        String?   @map("mobile_no")
  avatar          String?   @map("avatar")
  lang            String?   @map("lang")
  isEnableLogin   Boolean?  @map("is_enable_login")
  isActive        Boolean?  @map("is_active")
  activePlan      Int?      @map("active_plan")
  planExpireDate  DateTime? @db.Date @map("plan_expire_date")
  creatorId       BigInt?   @map("creator_id")
  createdBy       BigInt?   @map("created_by")
  emailVerifiedAt DateTime? @map("email_verified_at")
  partnerId       BigInt?   @map("partner_id")
  referralSource        String?   @map("referral_source")
  referredAt            DateTime? @map("referred_at")
  marketplaceVendorId   BigInt?   @map("marketplace_vendor_id")
  forcePasswordReset    Boolean   @default(false) @map("force_password_reset")
  operationsRole        String?   @map("operations_role")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime? @map("updated_at")

  sentMessages     Message[]          @relation("MessageSender")
  receivedMessages Message[]          @relation("MessageReceiver")
  favorites        MessengerFavorite[] @relation("FavoriteOwner")
  favoritedBy      MessengerFavorite[] @relation("FavoriteTarget")

  // Storefronts add-on: tenant = company user (organizationId on child rows → users.id)
  sfWebsites                 Website[]                 @relation("SfWebsiteOrganization")
  sfDomains                  Domain[]                  @relation("SfDomainOrganization")
  sfThemes                   Theme[]                   @relation("SfThemeOrganization")
  sfThemeTemplates           ThemeTemplate[]           @relation("SfThemeTemplateOrganization")
  sfPages                    Page[]                    @relation("SfPageOrganization")
  sfNotificationTemplates    NotificationTemplate[]    @relation("SfNotificationTemplateOrganization")
  sfNotificationLogs         NotificationLog[]         @relation("SfNotificationLogOrganization")
  sfEventLogs                EventLog[]                @relation("SfEventLogOrganization")
  sfCreatedWebsites          Website[]                 @relation("SfWebsiteCreatedBy")
  sfUpdatedWebsites          Website[]                 @relation("SfWebsiteUpdatedBy")
  sfCreatedDomains           Domain[]                  @relation("SfDomainCreatedBy")
  sfUpdatedDomains           Domain[]                  @relation("SfDomainUpdatedBy")
  sfCreatedThemes            Theme[]                   @relation("SfThemeCreatedBy")
  sfUpdatedThemes            Theme[]                   @relation("SfThemeUpdatedBy")
  sfCreatedThemeVersions     ThemeVersion[]            @relation("SfThemeVersionCreatedBy")
  sfUpdatedThemeVersions     ThemeVersion[]            @relation("SfThemeVersionUpdatedBy")
  sfCreatedThemeTemplates    ThemeTemplate[]           @relation("SfThemeTemplateCreatedBy")
  sfUpdatedThemeTemplates    ThemeTemplate[]           @relation("SfThemeTemplateUpdatedBy")
  sfCreatedPages             Page[]                    @relation("SfPageCreatedBy")
  sfUpdatedPages             Page[]                    @relation("SfPageUpdatedBy")
  sfCreatedPageVersions      PageVersion[]             @relation("SfPageVersionCreatedBy")
  sfUpdatedPageVersions      PageVersion[]             @relation("SfPageVersionUpdatedBy")
  sfCreatedNotifTemplates    NotificationTemplate[]    @relation("SfNotifTemplateCreatedBy")
  sfUpdatedNotifTemplates    NotificationTemplate[]    @relation("SfNotifTemplateUpdatedBy")
  sfCreatedNotifLogs         NotificationLog[]         @relation("SfNotifLogCreatedBy")
  sfCreatedEventLogs         EventLog[]                @relation("SfEventLogCreatedBy")
  sfEventLogActors           EventLog[]                @relation("SfEventLogActor")
  sfThemeVersionsOrg         ThemeVersion[]            @relation("SfThemeVersionOrganization")
  sfThemeSectionDefsOrg      ThemeSectionDefinition[]  @relation("SfThemeSectionDefOrganization")
  sfCreatedThemeSectionDefs  ThemeSectionDefinition[]  @relation("SfThemeSectionDefCreatedBy")
  sfUpdatedThemeSectionDefs  ThemeSectionDefinition[]  @relation("SfThemeSectionDefUpdatedBy")
  sfThemeBlockDefsOrg        ThemeBlockDefinition[]    @relation("SfThemeBlockDefOrganization")
  sfCreatedThemeBlockDefs    ThemeBlockDefinition[]    @relation("SfThemeBlockDefCreatedBy")
  sfUpdatedThemeBlockDefs    ThemeBlockDefinition[]    @relation("SfThemeBlockDefUpdatedBy")
  sfThemeStyleTokensOrg      ThemeStyleToken[]         @relation("SfThemeStyleTokenOrganization")
  sfCreatedThemeStyleTokens  ThemeStyleToken[]         @relation("SfThemeStyleTokenCreatedBy")
  sfUpdatedThemeStyleTokens  ThemeStyleToken[]         @relation("SfThemeStyleTokenUpdatedBy")
  sfPageVersionsOrg          PageVersion[]             @relation("SfPageVersionOrganization")
  sfSectionInstancesOrg      SectionInstance[]         @relation("SfSectionInstanceOrganization")
  sfCreatedSectionInstances  SectionInstance[]         @relation("SfSectionInstanceCreatedBy")
  sfUpdatedSectionInstances  SectionInstance[]         @relation("SfSectionInstanceUpdatedBy")
  sfBlockInstancesOrg        BlockInstance[]           @relation("SfBlockInstanceOrganization")
  sfCreatedBlockInstances    BlockInstance[]           @relation("SfBlockInstanceCreatedBy")
  sfUpdatedBlockInstances    BlockInstance[]           @relation("SfBlockInstanceUpdatedBy")
  sfCustomersAsOrg           StorefrontCustomer[]      @relation("SfCustomerOrganization")
  sfCustomersLinked          StorefrontCustomer[]      @relation("SfCustomerLinkedUser")
  posProductsOrganization    PosProduct[]              @relation("PosProductOrganization")
  posServicesOrganization    PosService[]              @relation("PosServiceOrganization")
  sfCollections              StorefrontCollection[]    @relation("SfCollectionOrganization")
  sfBlogPostsOrg             StorefrontBlogPost[]      @relation("SfBlogPostOrganization")
  sfCreatedBlogPosts         StorefrontBlogPost[]      @relation("SfBlogPostCreatedBy")
  sfUpdatedBlogPosts         StorefrontBlogPost[]      @relation("SfBlogPostUpdatedBy")
  sfStorefrontCarts          StorefrontCart[]          @relation("SfCartOrganization")
  sfStorefrontOrders         StorefrontOrder[]         @relation("SfOrderOrganization")
  sfCheckoutSessions         StorefrontCheckoutSession[] @relation("SfCheckoutSessionOrganization")
  sfStockReservations        StorefrontStockReservation[] @relation("SfStockReservationOrganization")
  sfDiscountRules            StorefrontDiscountRule[] @relation("SfDiscountRuleOrganization")
  sfDiscountCodes            StorefrontDiscountCode[] @relation("SfDiscountCodeOrganization")
  sfShippingZones            StorefrontShippingZone[] @relation("SfShippingZoneOrganization")
  sfTaxRules                 StorefrontTaxRule[] @relation("SfTaxRuleOrganization")
  sfTaxSettingsRows          StorefrontTaxSettings[] @relation("SfTaxSettingsOrganization")
  sfStTicketsOrg             StTicket[]            @relation("StTicketOrganization")
  sfStTicketsAssigned        StTicket[]            @relation("StTicketAssignedStaff")
  sfOrdersFulfillmentAssignee StorefrontOrder[]    @relation("SfOrderFulfillmentAssignee")
  sfKbArticlesOrg            StKnowledgeBase[]     @relation("StKbOrganization")

  emExpenseReportsOrg EmExpenseReport[] @relation("EmReportOrganization")
  emExpenseLinesOrg   EmExpenseLine[]   @relation("EmLineOrganization")
  emExpenseCategories EmExpenseCategory[] @relation("EmCategoryOrganization")
  emWorkspaceNotesOrg EmWorkspaceNote[] @relation("EmWorkspaceNoteOrganization")
  emWorkspaceNotesCreated EmWorkspaceNote[] @relation("EmWorkspaceNoteCreatedBy")
  emWorkspaceContext EmWorkspaceContext? @relation("EmWorkspaceContextOrganization")
  emTimeEntriesOrg EmTimeEntry[] @relation("EmTimeEntryOrganization")
  emCostAdjustmentsOrg EmCostAdjustment[] @relation("EmCostAdjustmentOrganization")
  emWorkspaceDocumentsOrg EmWorkspaceDocument[] @relation("EmWorkspaceDocumentOrganization")
  emWorkspaceDocumentsUploaded EmWorkspaceDocument[] @relation("EmWorkspaceDocumentUploadedBy")

  hrmEmployee HrmEmployee?

  // LMS add-on (organizationId → company tenant users.id)
  lmsCourseCategories         CourseCategory[]         @relation("LmsCourseCategoryOrganization")
  lmsCourseTags               CourseTag[]              @relation("LmsCourseTagOrganization")
  lmsCourses                  Course[]                 @relation("LmsCourseOrganization")
  lmsCoursesCreated           Course[]                 @relation("LmsCourseCreatedBy")
  lmsCoursesUpdated           Course[]                 @relation("LmsCourseUpdatedBy")
  lmsCourseSections           CourseSection[]          @relation("LmsCourseSectionOrganization")
  lmsCourseLessons            CourseLesson[]           @relation("LmsCourseLessonOrganization")
  lmsEnrollments              Enrollment[]             @relation("LmsEnrollmentOrganization")
  lmsEnrollmentsAsStudent     Enrollment[]             @relation("LmsEnrollmentStudent")
  lmsEnrollmentsAsInstructor  Enrollment[]             @relation("LmsEnrollmentInstructorUser")
  lmsInstructorProfiles       InstructorProfile[]      @relation("LmsInstructorProfileOrganization")
  lmsInstructorProfilesAsUser InstructorProfile[]      @relation("LmsInstructorProfileUser")
  lmsCourseInstructors        CourseInstructor[]       @relation("LmsCourseInstructorOrganization")
  lmsCourseTagOnCourses       CourseTagOnCourse[]      @relation("LmsCourseTagOnCourseOrganization")
  lmsLessonProgressRows       LmsLessonProgress[]      @relation("LmsLessonProgressOrganization")
  lmsLiveSessions             LmsLiveSession[]         @relation("LmsLiveSessionOrganization")
  lmsLiveSessionsCreated      LmsLiveSession[]         @relation("LmsLiveSessionCreatedBy")
  lmsEventCategories          LmsEventCategory[]       @relation("LmsEventCategoryOrganization")
  lmsEvents                   LmsTrainingEvent[]       @relation("LmsTrainingEventOrganization")
  lmsEventRegistrations       LmsEventRegistration[]   @relation("LmsEventRegistrationOrganization")
  lmsEventRegistrationsAsStudent LmsEventRegistration[]  @relation("LmsEventRegistrationStudent")
  lmsEventCertificates        LmsEventCertificate[]    @relation("LmsEventCertificateOrganization")
  lmsEventCertificatesAsStudent LmsEventCertificate[]  @relation("LmsEventCertificateStudent")
  lmsEventSupportTickets      LmsEventSupportTicket[]  @relation("LmsEventSupportTicketOrganization")
  lmsEventSupportTicketsAsStudent LmsEventSupportTicket[] @relation("LmsEventSupportTicketStudent")
  lmsEventNotifications       LmsEventNotification[]   @relation("LmsEventNotificationOrganization")
  lmsEventNotificationsAsUser LmsEventNotification[]   @relation("LmsEventNotificationUser")
  lmsEventWishlist            LmsEventWishlistItem[]   @relation("LmsEventWishlistOrganization")
  lmsEventWishlistAsStudent   LmsEventWishlistItem[]   @relation("LmsEventWishlistStudent")
  epEventVendors              EventVendor[]            @relation("EpEventVendorOrganization")
  epEventVenues               EventVenue[]             @relation("EpEventVenueOrganization")
  epEventCommissionLedger     EventCommissionLedger[]  @relation("EpCommissionLedgerOrganization")
  epEventVendorPayouts        EventVendorPayout[]      @relation("EpVendorPayoutOrganization")
  epEventSeatmapTemplates     EventSeatmapTemplate[]   @relation("EpSeatmapTemplateOrganization")
  epEventCustomPages          EventCustomPage[]        @relation("EpCustomPageOrganization")
  epEventMenus                EventMenu[]              @relation("EpMenuOrganization")
  epEventAnnouncementPopups   EventAnnouncementPopup[] @relation("EpPopupOrganization")
  epEventAuditLogs            EventAuditLog[]          @relation("EpAuditLogOrganization")
  lmsLiveAttendanceRows       LmsLiveAttendance[]      @relation("LmsLiveAttendanceOrganization")
  lmsLiveAttendanceMarked     LmsLiveAttendance[]      @relation("LmsLiveAttendanceMarkedBy")
  googleCalendarConnection       UserGoogleCalendarConnection? @relation("UserGoogleCalendarConnection")
  googleCalendarConnectionsOrg   UserGoogleCalendarConnection[] @relation("UserGoogleCalendarConnectionOrganization")
  lmsUserCalendarEventLinks      LmsUserCalendarEventLink[] @relation("LmsUserCalendarEventLinkUser")
  lmsNotificationLogs          LmsNotificationLog[]       @relation("LmsNotificationLogOrganization")
  emNotificationLogs           EmNotificationLog[]        @relation("EmNotificationLogOrganization")
  lmsSubscriptionPlans         LmsSubscriptionPlan[]      @relation("LmsSubscriptionPlanOrganization")
  lmsStudentSubscriptions      LmsStudentSubscription[]   @relation("LmsStudentSubscriptionOrganization")
  lmsStudentSubscriptionsAsStudent LmsStudentSubscription[] @relation("LmsStudentSubscriptionStudent")
  lmsSubscriptionPlanCourses   LmsSubscriptionPlanCourse[]  @relation("LmsSubscriptionPlanCourseOrganization")
  lmsCourseRevenueRecords      LmsCourseRevenueRecord[]     @relation("LmsCourseRevenueOrganization")
  lmsInstructorCommissions     LmsInstructorCommission[]    @relation("LmsInstructorCommissionOrganization")
  lmsInstructorPayouts         LmsInstructorPayout[]        @relation("LmsInstructorPayoutOrganization")
  lmsCourseReviews             LmsCourseReview[]            @relation("LmsCourseReviewOrganization")
  lmsCourseReviewsAsStudent    LmsCourseReview[]            @relation("LmsCourseReviewStudent")
  lmsCourseReviewsModerated    LmsCourseReview[]            @relation("LmsCourseReviewModerator")
  lmsSupportTicketsAsStudent   StTicket[]                   @relation("StTicketLmsStudent")

  affiliatePartnersOrg     AffiliatePartner[]     @relation("AffiliatePartnerOrganization")
  affiliateProgramsOrg     AffiliateProgram[]     @relation("AffiliateProgramOrganization")
  affiliateLinksOrg        AffiliateLink[]        @relation("AffiliateLinkOrganization")
  affiliateCommissionsOrg  AffiliateCommission[]  @relation("AffiliateCommissionOrganization")
  affiliatePayoutsOrg      AffiliatePayout[]      @relation("AffiliatePayoutOrganization")
  affiliateSettingsOrg     AffiliateSettings?     @relation("AffiliateSettingsOrganization")

  complianceFrameworksOrg      ComplianceFramework[]      @relation("ComplianceFrameworkOrganization")
  complianceControlsOrg          ComplianceControl[]        @relation("ComplianceControlOrganization")
  complianceControlMappingsOrg   ComplianceControlMapping[] @relation("ComplianceControlMappingOrganization")
  complianceEvidenceOrg          ComplianceEvidence[]       @relation("ComplianceEvidenceOrganization")
  compliancePoliciesOrg          CompliancePolicy[]         @relation("CompliancePolicyOrganization")
  complianceDocumentsOrg         ComplianceDocument[]       @relation("ComplianceDocumentOrganization")
  complianceMonitorsOrg          ComplianceMonitor[]        @relation("ComplianceMonitorOrganization")
  complianceMonitorResultsOrg    ComplianceMonitorResult[]  @relation("ComplianceMonitorResultOrganization")
  complianceRisksOrg             ComplianceRisk[]           @relation("ComplianceRiskOrganization")
  complianceVendorReviewsOrg     ComplianceVendorReview[]   @relation("ComplianceVendorReviewOrganization")
  complianceAccessReviewsOrg     ComplianceAccessReview[]   @relation("ComplianceAccessReviewOrganization")
  complianceVulnerabilitiesOrg   ComplianceVulnerability[] @relation("ComplianceVulnerabilityOrganization")
  complianceAuditsOrg              ComplianceAudit[]          @relation("ComplianceAuditOrganization")
  complianceTasksOrg               ComplianceTask[]           @relation("ComplianceTaskOrganization")
  complianceIntegrationsOrg        ComplianceIntegration[]    @relation("ComplianceIntegrationOrganization")
  complianceActivityLogsOrg        ComplianceActivityLog[]    @relation("ComplianceActivityLogOrganization")
  complianceNotificationsOrg       ComplianceNotification[]   @relation("ComplianceNotificationOrganization")
  complianceTrustCenterOrg         ComplianceTrustCenter?     @relation("ComplianceTrustCenterOrganization")
  complianceAuditorInvitesOrg      ComplianceAuditorInvite[]  @relation("ComplianceAuditorInviteOrganization")
  complianceCommentsOrg            ComplianceComment[]        @relation("ComplianceCommentOrganization")
  complianceAttachmentsOrg         ComplianceAttachment[]     @relation("ComplianceAttachmentOrganization")
  compliancePolicyAcksOrg          CompliancePolicyAcknowledgement[] @relation("CompliancePolicyAckOrganization")
  complianceControlRemediationsOrg ComplianceControlRemediation[] @relation("ComplianceControlRemediationOrganization")

  @@map("users")
}

model Role {
  id        BigInt    @id
  name      String
  label     String
  guardName String    @map("guard_name")
  editable  Boolean   @default(true)
  createdBy BigInt?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@unique([name, guardName])
  @@map("roles")
}

model Permission {
  id        BigInt    @id
  addOn     String    @map("add_on")
  module    String
  label     String
  name      String
  guardName String    @map("guard_name")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@unique([name, guardName])
  @@map("permissions")
}

model RoleHasPermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  @@id([roleId, permissionId])
  @@map("role_has_permissions")
}

model ModelHasRole {
  roleId    BigInt @map("role_id")
  modelId   BigInt @map("model_id")
  modelType String @map("model_type")

  @@id([roleId, modelId, modelType])
  @@map("model_has_roles")
}

// Partnership module: platform-level referral partners (distinct from per-tenant AffiliatePartner).
model Partner {
  id             BigInt    @id
  userId         BigInt?   @map("user_id")
  name           String
  email          String?
  phone          String?
  brandName      String?   @map("brand_name")
  slug           String    @unique
  referralCode   String    @unique @map("referral_code")
  commissionRate Decimal?  @db.Decimal(5, 2) @map("commission_rate")
  // Optional marketplace commission rule, separate from the subscription commissionRate above.
  // Type: "percentage" | "flat" | null (null = use platform marketplace default / off).
  marketplaceCommissionType  String?  @map("marketplace_commission_type") @db.VarChar(16)
  marketplaceCommissionValue Decimal? @map("marketplace_commission_value") @db.Decimal(10, 2)
  status         String    @default("pending")
  payoutMethod   String?   @map("payout_method")
  payoutEmail    String?   @map("payout_email")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("partners")
}

model PartnerReferral {
  id             BigInt    @id
  partnerId      BigInt    @map("partner_id")
  companyId      BigInt?   @map("company_id")
  referralCode   String?   @map("referral_code")
  partnerSlug    String?   @map("partner_slug")
  sourceUrl      String?   @map("source_url")
  signupDate     DateTime? @map("signup_date")
  referralStatus String    @default("pending") @map("referral_status")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  @@index([partnerId])
  @@index([companyId])
  @@map("partner_referrals")
}

model PartnerCommission {
  id               BigInt    @id
  partnerId        BigInt    @map("partner_id")
  companyId        BigInt    @map("company_id")
  // Source separates subscription commissions from marketplace commissions.
  // Existing rows + the subscription flow default to "subscription"; marketplace uses "marketplace".
  sourceType         String   @default("subscription") @map("source_type") @db.VarChar(32)
  subscriptionId     BigInt?  @map("subscription_id")
  invoiceId          BigInt?  @map("invoice_id")
  marketplaceOrderId BigInt?  @map("marketplace_order_id")
  orderRef         String?   @unique @map("order_ref")
  amount           Decimal   @db.Decimal(10, 2)
  commissionRate   Decimal   @db.Decimal(5, 2) @map("commission_rate")
  commissionAmount Decimal   @db.Decimal(10, 2) @map("commission_amount")
  status           String    @default("pending")
  payoutId         BigInt?   @map("payout_id")
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  @@index([partnerId])
  @@index([companyId])
  @@index([status])
  @@index([payoutId])
  @@index([sourceType])
  @@index([marketplaceOrderId])
  @@map("partner_commissions")
}

model PartnerPayout {
  id              BigInt    @id
  partnerId       BigInt    @map("partner_id")
  totalAmount     Decimal   @db.Decimal(10, 2) @map("total_amount")
  status          String    @default("pending")
  payoutMethod    String?   @map("payout_method")
  payoutReference String?   @map("payout_reference")
  notes           String?
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  @@index([partnerId])
  @@index([status])
  @@map("partner_payouts")
}

model PartnerLandingPage {
  id               BigInt    @id
  partnerId        BigInt    @map("partner_id")
  title            String
  slug             String
  headline         String?
  subheadline      String?
  industryModule   String?   @map("industry_module")
  logo             String?
  description      String?
  callToActionText String?   @map("call_to_action_text")
  status           String    @default("draft")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  @@unique([partnerId, slug])
  @@index([partnerId])
  @@map("partner_landing_pages")
}

// Brand Ownership module: percentage-based brand ownership (distinct from partnership commission rates).
model OwnershipBrand {
  id        BigInt    @id
  name      String
  firstName String?   @map("first_name")
  lastName  String?   @map("last_name")
  slug      String    @unique
  logo      String?
  status    String    @default("active")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  holders  OwnershipBrandHolder[]
  history  OwnershipBrandHistory[]
  requests OwnershipBrandRequest[]

  @@index([status])
  @@map("ownership_brands")
}

model OwnershipBrandHolder {
  id                       BigInt    @id
  brandId                  BigInt    @map("brand_id")
  partnerId                BigInt?   @map("partner_id")
  name                     String
  firstName                String?   @map("first_name")
  lastName                 String?   @map("last_name")
  email                    String?
  phone                    String?
  referralCode             String?   @map("referral_code")
  currentOwnershipPercent  Decimal   @map("current_ownership_percent") @db.Decimal(5, 2)
  minimumOwnershipPercent  Decimal   @map("minimum_ownership_percent") @db.Decimal(5, 2)
  isPrimaryBrandHolder     Boolean   @default(false) @map("is_primary_brand_holder")
  status                   String    @default("active")
  payoutMethod             String?   @map("payout_method")
  payoutEmail              String?   @map("payout_email")
  notes                    String?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime? @map("updated_at")

  brand OwnershipBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  agreement OwnershipPartnershipAgreement?

  @@index([brandId])
  @@index([partnerId])
  @@index([status])
  @@map("ownership_brand_holders")
}

model OwnershipBrandHistory {
  id                          BigInt   @id
  brandId                     BigInt   @map("brand_id")
  holderId                    BigInt?  @map("holder_id")
  action                      String
  oldCurrentOwnershipPercent  Decimal? @map("old_current_ownership_percent") @db.Decimal(5, 2)
  newCurrentOwnershipPercent  Decimal? @map("new_current_ownership_percent") @db.Decimal(5, 2)
  oldMinimumOwnershipPercent  Decimal? @map("old_minimum_ownership_percent") @db.Decimal(5, 2)
  newMinimumOwnershipPercent  Decimal? @map("new_minimum_ownership_percent") @db.Decimal(5, 2)
  changedByUserId             BigInt?  @map("changed_by_user_id")
  notes                       String?
  createdAt                   DateTime @default(now()) @map("created_at")

  brand OwnershipBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([holderId])
  @@index([createdAt])
  @@map("ownership_brand_history")
}

model OwnershipBrandRequest {
  id                          BigInt    @id
  brandId                     BigInt    @map("brand_id")
  holderId                    BigInt?   @map("holder_id")
  partnerName                 String    @map("partner_name")
  email                       String?
  phone                       String?
  referralCode                String?   @map("referral_code")
  requestedCurrentOwnership   Decimal   @map("requested_current_ownership") @db.Decimal(5, 2)
  requestedMinimumOwnership   Decimal   @map("requested_minimum_ownership") @db.Decimal(5, 2)
  status                      String    @default("pending")
  conflictDetected            Boolean   @default(false) @map("conflict_detected")
  conflictMessage             String?   @map("conflict_message")
  notes                       String?
  requestedByUserId           BigInt?   @map("requested_by_user_id")
  createdAt                   DateTime  @default(now()) @map("created_at")
  updatedAt                   DateTime? @map("updated_at")

  brand OwnershipBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([holderId])
  @@index([status])
  @@map("ownership_brand_requests")
}

model OwnershipPartnershipAgreement {
  id                    BigInt    @id
  holderId              BigInt    @unique @map("holder_id")
  signToken             String    @unique @map("sign_token")
  brandApprovalToken    String    @unique @map("brand_approval_token")
  status                String    @default("pending_signature")
  signatureData         String?   @map("signature_data") @db.Text
  signedName            String?   @map("signed_name")
  signedAt              DateTime? @map("signed_at")
  brandApprovedAt       DateTime? @map("brand_approved_at")
  brandApprovedByUserId BigInt?   @map("brand_approved_by_user_id")
  brandApprovedByName   String?   @map("brand_approved_by_name")
  brandRejectionNotes   String?   @map("brand_rejection_notes") @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime? @map("updated_at")

  holder OwnershipBrandHolder @relation(fields: [holderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("ownership_partnership_agreements")
}

model Plan {
  id                   BigInt   @id
  name                 String?
  description          String?
  numberOfUsers        Int      @default(1) @map("number_of_users")
  customPlan           Boolean  @default(false) @map("custom_plan")
  status               Boolean  @default(true)
  freePlan             Boolean  @default(false) @map("free_plan")
  modules              Json?    // array of module codes
  packagePriceYearly   Decimal  @default(0) @db.Decimal(10, 2) @map("package_price_yearly")
  packagePriceMonthly  Decimal  @default(0) @db.Decimal(10, 2) @map("package_price_monthly")
  pricePerUserMonthly  Decimal  @default(0) @db.Decimal(10, 2) @map("price_per_user_monthly")
  pricePerUserYearly   Decimal  @default(0) @db.Decimal(10, 2) @map("price_per_user_yearly")
  storageLimit         Int      @default(0) @map("storage_limit")
  pricePerStorageMonthly Decimal @default(0) @db.Decimal(10, 2) @map("price_per_storage_monthly")
  pricePerStorageYearly  Decimal @default(0) @db.Decimal(10, 2) @map("price_per_storage_yearly")
  trial                Boolean  @default(false)
