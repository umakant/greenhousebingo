  subtotal        Decimal   @db.Decimal(15, 4) @default(0)
  taxAmount       Decimal   @db.Decimal(15, 4) @default(0) @map("tax_amount")
  discount        Decimal   @db.Decimal(15, 4) @default(0)
  total           Decimal   @db.Decimal(15, 4)
  paid            Decimal   @db.Decimal(15, 4) @default(0)
  paymentMethod   String    @default("cash") @map("payment_method")
