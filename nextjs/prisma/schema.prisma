  lastName    String?   @map("last_name")
  email       String?
  phone       String?
  company     String?
  source      String?
  status      String    @default("new")
  value       Decimal?  @db.Decimal(15, 2)
  notes       String?   @db.Text
  pipelineId  BigInt?   @map("pipeline_id")
  stageId     BigInt?   @map("stage_id")
