// ─── Form Builder ────────────────────────────────────────────────────────────

model Form {
  id                BigInt    @id @default(autoincrement())
  name              String
  code              String    @unique
  isActive          Boolean   @default(true)  @map("is_active")
  defaultLayout     String    @default("single") @map("default_layout")
  projectSectionId  String?   @map("project_section_id")
  createdBy         BigInt?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @map("updated_at")

  fields      FormField[]
  responses   FormResponse[]
  conversion  FormConversion?

  @@index([createdBy])
  @@index([projectSectionId])
  @@map("forms")
}

model FormField {
  id          BigInt    @id @default(autoincrement())
  formId      BigInt    @map("form_id")
  label       String
  type        String
  required    Boolean   @default(false)
  placeholder String?
  options     Json?
  order       Int       @default(0)
  createdBy   BigInt?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @map("updated_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([createdBy])
  @@map("form_fields")
}

model FormResponse {
  id           BigInt    @id @default(autoincrement())
  formId       BigInt    @map("form_id")
  responseData Json      @map("response_data")
  submitterIp  String?   @map("submitter_ip")
  createdBy    BigInt?   @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@map("form_responses")
}

model FormConversion {
  id            BigInt    @id @default(autoincrement())
  formId        BigInt    @unique @map("form_id")
  moduleName    String    @map("module_name")
  submoduleName String?   @map("submodule_name")
  isActive      Boolean   @default(false) @map("is_active")
  fieldMappings Json      @map("field_mappings")
  createdBy     BigInt?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@map("form_conversions")
}

