  quantity           Int
  unitPrice          Decimal  @db.Decimal(15, 2) @map("unit_price")
  discountPercentage Decimal  @default(0) @db.Decimal(5, 2) @map("discount_percentage")
  discountAmount     Decimal  @default(0) @db.Decimal(15, 2) @map("discount_amount")
  taxPercentage      Decimal  @default(0) @db.Decimal(5, 2) @map("tax_percentage")
  taxAmount          Decimal  @default(0) @db.Decimal(15, 2) @map("tax_amount")
  totalAmount        Decimal  @default(0) @db.Decimal(15, 2) @map("total_amount")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt         DateTime? @map("updated_at")

  proposal SalesProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([productId])
  @@map("sales_proposal_items")
}

