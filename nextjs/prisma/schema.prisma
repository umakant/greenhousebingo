  isActive      Boolean   @default(true)  @map("is_active")
  createdBy     BigInt?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @map("updated_at")

  department    HrmDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employees     HrmEmployee[]
  promotionsFrom HrmPromotion[] @relation("PromoFromDesig")
  promotionsTo   HrmPromotion[] @relation("PromoToDesig")

  @@index([departmentId])
  @@index([createdBy])
  @@map("hrm_designations")
}

model HrmEmployee {
  id                  BigInt    @id @default(autoincrement())
  employeeId          String?   @unique @map("employee_id")
  firstName           String    @map("first_name")
  lastName            String?   @map("last_name")
  email               String?
  phone               String?
  gender              String?
  dateOfBirth         DateTime? @map("date_of_birth") @db.Date
  address             String?   @db.Text
  city                String?
  country             String?
  departmentId        BigInt?   @map("department_id")
  designationId       BigInt?   @map("designation_id")
  branchId            BigInt?   @map("branch_id")
  shiftId             BigInt?   @map("shift_id")
  managerId           BigInt?   @map("manager_id")
  status              String    @default("active")
  employeeType        String?   @map("employee_type")
  workType            String?   @map("work_type")
  joiningDate         DateTime? @map("joining_date") @db.Date
  leavingDate         DateTime? @map("leaving_date") @db.Date
  basicSalary         Decimal?  @map("basic_salary") @db.Decimal(15, 2)
  bankName            String?   @map("bank_name")
  bankAccountNumber   String?   @map("bank_account_number")
  bankBranchCode      String?   @map("bank_branch_code")
  emergencyName       String?   @map("emergency_name")
  emergencyPhone      String?   @map("emergency_phone")
  profilePhoto        String?   @map("profile_photo")
  notes               String?   @db.Text
  userId              BigInt?   @unique @map("user_id")
  createdBy           BigInt?   @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @map("updated_at")

  user                User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  department          HrmDepartment?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation         HrmDesignation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  branch              HrmBranch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  shift               HrmShift?       @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  attendances         HrmAttendance[]
  leaveApplications   HrmLeaveApplication[]
  awards              HrmAward[]
  promotions          HrmPromotion[]
  resignations        HrmResignation[]
  terminations        HrmTermination[]
  warnings            HrmWarning[]
  complaintsBy        HrmComplaint[] @relation("ComplainantEmployee")
  complaintsAgainst   HrmComplaint[] @relation("AgainstEmployee")
  transfers           HrmTransfer[]
  documents           HrmDocument[]
  acknowledgments     HrmAcknowledgment[]
  salaryAllocation    HrmSalaryAllocation?
  payrolls            HrmPayroll[]

  @@index([departmentId])
  @@index([designationId])
  @@index([branchId])
  @@index([createdBy])
  @@index([userId])
  @@map("hrm_employees")
}

model HrmShift {
  id             BigInt    @id @default(autoincrement())
  name           String
  startTime      String    @map("start_time")
  endTime        String    @map("end_time")
  breakMinutes   Int       @default(0) @map("break_minutes")
  isActive       Boolean   @default(true)  @map("is_active")
  createdBy      BigInt?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  employees HrmEmployee[]

  @@index([createdBy])
  @@map("hrm_shifts")
}

model HrmAttendance {
  id          BigInt    @id @default(autoincrement())
  employeeId  BigInt    @map("employee_id")
  date        DateTime  @db.Date
  clockIn     String?   @map("clock_in")
  clockOut    String?   @map("clock_out")
  workHours   Decimal?  @map("work_hours") @db.Decimal(5, 2)
  status      String    @default("present")
  note        String?   @db.Text
  createdBy   BigInt?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @map("updated_at")

  employee HrmEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([createdBy])
  @@map("hrm_attendances")
}

model HrmLeaveType {
  id           BigInt    @id @default(autoincrement())
  name         String
  daysAllowed  Int       @default(0) @map("days_allowed")
  leaveCode    String?   @map("leave_code")
