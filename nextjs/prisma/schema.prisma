// Sales Proposals (Laravel: sales_proposals)
model SalesProposal {
  id                 BigInt    @id @default(autoincrement())
  proposalNumber     String    @map("proposal_number")
  proposalDate       DateTime  @db.Date @map("proposal_date")
  dueDate            DateTime  @db.Date @map("due_date")
  customerId         BigInt    @map("customer_id")
  warehouseId        BigInt?   @map("warehouse_id")
  subtotal           Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount          Decimal   @default(0) @db.Decimal(15, 2) @map("tax_amount")
  discountAmount     Decimal   @default(0) @db.Decimal(15, 2) @map("discount_amount")
  totalAmount        Decimal   @default(0) @db.Decimal(15, 2) @map("total_amount")
  status             String    @default("draft") @db.VarChar(20)
  convertedToInvoice Boolean  @default(false) @map("converted_to_invoice")
  invoiceId          BigInt?   @map("invoice_id")
  leadId             BigInt?   @map("lead_id")
  dealId             BigInt?   @map("deal_id")
  projectId          BigInt?   @map("project_id")
  projectName        String?   @map("project_name")
  currency           String    @default("USD") @db.VarChar(8)
  calculateTax       String?   @map("calculate_tax") @db.VarChar(32)
  description        String?   @db.Text
  requireSignature   Boolean   @default(true) @map("require_signature")
  paymentTerms       String?   @map("payment_terms")
  notes              String?   @db.Text
  creatorId          BigInt?   @map("creator_id")
  createdBy          BigInt?   @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @map("updated_at")

  items SalesProposalItem[]

  @@index([customerId])
  @@index([status, proposalDate])
  @@index([createdBy])
  @@map("sales_proposals")
}

model SalesProposalItem {
  id                 BigInt   @id @default(autoincrement())
