model StTicket {
  id          BigInt    @id @default(autoincrement())
  ticketCode  String    @unique @map("ticket_code")
  accountType String    @default("custom") @map("account_type")
  name        String
  email       String
  subject     String
  categoryId  BigInt?   @map("category_id")
  status      String    @default("open")
  description String?   @db.Text
  attachments Json      @default("[]")
  createdBy   BigInt?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @map("updated_at")
  /// Tenant (company user id) when ticket originates from Storefronts / merchant context.
  organizationId           BigInt? @map("organization_id")
  websiteId                BigInt? @map("website_id")
  storefrontCustomerId     BigInt? @map("storefront_customer_id")
  storefrontOrderId        BigInt? @map("storefront_order_id")
  assignedStaffUserId      BigInt? @map("assigned_staff_user_id")
  /// LMS course question (learner support per course).
  lmsCourseId              BigInt? @map("lms_course_id")
  lmsLessonId              BigInt? @map("lms_lesson_id")
  lmsStudentUserId         BigInt? @map("lms_student_user_id")
  /// Marketplace order support (raised by a buying company from an order detail page).
  marketplaceOrderId       BigInt? @map("marketplace_order_id")
  marketplaceVendorId      BigInt? @map("marketplace_vendor_id")
  deliveryEventId          BigInt? @map("delivery_event_id")

  category            StTicketCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  organization        User?                @relation("StTicketOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  website             Website?             @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  storefrontCustomer  StorefrontCustomer?  @relation(fields: [storefrontCustomerId], references: [id], onDelete: SetNull)
  storefrontOrder     StorefrontOrder?     @relation(fields: [storefrontOrderId], references: [id], onDelete: SetNull)
  assignedStaff       User?                @relation("StTicketAssignedStaff", fields: [assignedStaffUserId], references: [id], onDelete: SetNull)
  lmsCourse           Course?              @relation(fields: [lmsCourseId], references: [id], onDelete: SetNull)
  lmsLesson           CourseLesson?        @relation(fields: [lmsLessonId], references: [id], onDelete: SetNull)
  lmsStudent          User?                @relation("StTicketLmsStudent", fields: [lmsStudentUserId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([createdBy])
  @@index([organizationId])
  @@index([websiteId])
  @@index([storefrontCustomerId])
  @@index([storefrontOrderId])
  @@index([assignedStaffUserId])
  @@index([lmsCourseId])
  @@index([lmsLessonId])
  @@index([lmsStudentUserId])
  @@index([marketplaceOrderId])
  @@index([marketplaceVendorId])
  @@index([deliveryEventId])
  @@map("st_tickets")
}

