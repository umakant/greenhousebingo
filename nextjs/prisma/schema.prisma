  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  products PosProduct[]
  services PosService[]

  @@map("pos_units")
}

model PosTax {
  id        BigInt    @id @default(autoincrement())
  name      String
  rate      Decimal   @db.Decimal(10, 4)
  type      String    @default("percentage")
  createdBy BigInt?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  products PosProduct[]
  services PosService[]

  @@map("pos_taxes")
}

model PosProduct {
  id          BigInt    @id @default(autoincrement())
  name        String
  description String?   @db.Text
  barcode     String?
  price       Decimal   @db.Decimal(15, 4)
  cost        Decimal   @db.Decimal(15, 4) @default(0)
  stock       Int       @default(0)
  stockAlert  Int       @default(5) @map("stock_alert")
  categoryId  BigInt?   @map("category_id")
  brandId     BigInt?   @map("brand_id")
  unitId      BigInt?   @map("unit_id")
  taxId       BigInt?   @map("tax_id")
  image       String?
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   BigInt?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  /// Tenant scope for POS + storefront catalog (users.id of company owner).
  organizationId BigInt? @map("organization_id")
  /// URL segment for public /shop/products/{slug}
  slug           String?
  sku            String?
  compareAtPrice Decimal? @db.Decimal(15, 4) @map("compare_at_price")
  /// When true and slug set, product may appear on the public storefront (Day 21–24).
  storefrontPublished Boolean @default(false) @map("storefront_published")
  /// When set to a future instant, the product stays off the public storefront until that time (Shopify-style scheduled publishing).
  storefrontPublishAt DateTime? @map("storefront_publish_at")
  storefrontSeoTitle       String? @map("storefront_seo_title") @db.VarChar(512)
  storefrontSeoDescription String? @map("storefront_seo_description") @db.Text
  /// Ordered image URLs for gallery (JSON array of strings).
  galleryImages     Json?   @map("gallery_images")
  relatedProductIds Json?   @map("related_product_ids")
  /// Page template key for storefront rendering (e.g. product, product_wide).
  pageTemplateKey   String? @default("product") @map("page_template_key")
  /// Optional variants: [{ "id": string, "name": string, "sku"?: string, "price": number, "stock": number }]
  variants          Json?
  /// track | continue | deny — storefront stock behavior (Day 22).
  inventoryPolicy String               @default("track") @map("inventory_policy")
  /// Highlight on homepage / flavor grid when theme customizer uses featured ordering.
  storefrontFeatured Boolean           @default(false) @map("storefront_featured")
  /// Optional homepage spotlight “Why you’ll love it” cards: `[{ "title", "subtitle?", "imageUrl?" }]` or `{ "heading"?, "items": [...] }`.
  storefrontHighlights Json?          @map("storefront_highlights")
  /// Water Ice Express landing flavor metadata: `{ "category", "rating", "reviews", "ingredients": string[], "tastingNotes", "pairsWith": string[] }`.
  flavorMeta           Json?          @map("flavor_meta")
  /// Water Ice Express landing eBook metadata: `{ "category", "pages", "rating", "reviews", "tagline", "highlights": string[], "chapters": string[], "author": { "name", "role" } }`.
  ebookMeta            Json?          @map("ebook_meta")

  category       PosCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand          PosBrand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit           PosUnit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tax            PosTax?              @relation(fields: [taxId], references: [id], onDelete: SetNull)
  organization   User?                @relation("PosProductOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  saleItems      PosSaleItem[]
  purchaseItems  PosPurchaseItem[]
  quotationItems PosQuotationItem[]
  collectionLinks       StorefrontCollectionProduct[]
  storefrontCartLines   StorefrontCartLine[]
  storefrontOrderLines StorefrontOrderLine[]
  storefrontStockReservations StorefrontStockReservation[]
  /// LMS courses that bill through this catalog product (checkout / POS pricing).
  lmsLinkedCourses Course[] @relation("LmsCourseLinkedProduct")
  lmsSubscriptionPlans LmsSubscriptionPlan[] @relation("LmsSubscriptionPlanLinkedProduct")

  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([taxId])
  @@index([organizationId])
  @@index([organizationId, slug])
  @@index([organizationId, storefrontPublished])
  @@index([organizationId, storefrontFeatured])
  @@map("pos_products")
}

model PosService {
  id             BigInt    @id @default(autoincrement())
