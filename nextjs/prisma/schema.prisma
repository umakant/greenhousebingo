  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  lead CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("crm_lead_activities")
}

model CrmDeal {
  id          BigInt    @id @default(autoincrement())
  name        String
  amount      Decimal?  @db.Decimal(15, 2)
  status      String    @default("open")
  pipelineId  BigInt?   @map("pipeline_id")
  stageId     BigInt?   @map("stage_id")
  leadId      BigInt?   @map("lead_id")
  assignedTo  BigInt?   @map("assigned_to")
  closeDate   DateTime? @map("close_date")
  notes       String?   @db.Text
  createdBy   BigInt?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  pipeline   CrmPipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stage      CrmPipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  lead       CrmLead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  activities CrmDealActivity[]

  @@index([pipelineId])
  @@index([stageId])
  @@index([leadId])
  @@index([createdBy])
  @@map("crm_deals")
}

model CrmDealActivity {
  id        BigInt    @id @default(autoincrement())
  dealId    BigInt    @map("deal_id")
  userId    BigInt?   @map("user_id")
  type      String    @default("note")
  note      String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  deal CrmDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@map("crm_deal_activities")
