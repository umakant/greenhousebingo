# /etc/nginx/sites-available/securxpro.com
# Impersonation sets several large cookies — raise proxy buffers or nginx returns 502.

server {
    listen 80;
    server_name securxpro.com www.securxpro.com;

    client_max_body_size 100M;

    # Required when Set-Cookie headers are large (impersonation, permissions cookie)
    proxy_buffer_size 128k;
    proxy_buffers 8 256k;
    proxy_busy_buffers_size 256k;
    large_client_header_buffers 8 64k;

    location / {
        proxy_pass http://127.0.0.1:5025;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
        proxy_connect_timeout 60;
        proxy_send_timeout 300;
    }
}
