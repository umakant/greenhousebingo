# /etc/nginx/sites-available/greenhousebingo.com
#
# Company marketing subdomains (e.g. socialgreenhouse.greenhousebingo.com) MUST use
# this same server block — NOT a separate Vite/Lovable preview server.
#
# Install:
#   sudo cp /var/www/apps/greenhousebingo/deploy/greenhousebingo.nginx.example \
#           /etc/nginx/sites-available/greenhousebingo.com
#   sudo ln -sf /etc/nginx/sites-available/greenhousebingo.com /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# SSL: use certbot after HTTP works:
#   sudo certbot --nginx -d greenhousebingo.com -d '*.greenhousebingo.com'

# Redirect HTTP -> HTTPS (optional; certbot can manage this)
server {
    listen 80;
    server_name greenhousebingo.com *.greenhousebingo.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name greenhousebingo.com *.greenhousebingo.com;

    # certbot fills these paths:
    # ssl_certificate     /etc/letsencrypt/live/greenhousebingo.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/greenhousebingo.com/privkey.pem;

    client_max_body_size 100M;

    proxy_buffer_size 128k;
    proxy_buffers 8 256k;
    proxy_busy_buffers_size 256k;
    large_client_header_buffers 8 64k;

    location / {
        proxy_pass http://127.0.0.1:5030;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
        proxy_connect_timeout 60;
        proxy_send_timeout 300;
    }
}

# HTTP-only fallback (if you do not use SSL yet):
# server {
#     listen 80;
#     server_name greenhousebingo.com *.greenhousebingo.com;
#     location / {
#         proxy_pass http://127.0.0.1:5030;
#         proxy_set_header Host $host;
#         proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#         proxy_set_header X-Forwarded-Proto $scheme;
#     }
# }
